<UserControl x:Class="RDimm_MMTCRACK.View.Component.CBoxUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RDimm_MMTCRACK.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="500">
    <Grid Margin="0,5,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" Margin="5,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HumidityValue}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" Width="25" Foreground="{Binding HumRateColor}" FontWeight="DemiBold"/>
                <TextBox Text="{Binding BoxTempText}" IsReadOnly="True" Width="50" Margin="5,0,0,0" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
            </StackPanel>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding DimModels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DimColumns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" BorderBrush="#aa000000" Margin="2" Height="26" MaxWidth="50" CornerRadius="3">
                            <TextBox Background="{Binding DimColor}" Text="{Binding DimText}" Foreground="{Binding DimTextColor}" FontSize="11" FontWeight="DemiBold" TextAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <TextBox.Resources>
                                    <Style TargetType="TextBox"></Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <Rectangle Fill="{Binding BoxColor}" Margin="-1" RadiusX="4" RadiusY="4"></Rectangle>
    </Grid>
</UserControl>
