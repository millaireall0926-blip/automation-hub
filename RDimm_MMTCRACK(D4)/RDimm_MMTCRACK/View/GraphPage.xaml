<Page x:Class="RDimm_MMTCRACK.View.GraphPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RDimm_MMTCRACK.View"
      xmlns:vm="clr-namespace:RDimm_MMTCRACK.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1250"
      Title="GraphPage">

    <Page.DataContext>
        <vm:GraphVM/>
    </Page.DataContext>
    
    <Grid Margin="10">
        <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="10">
            <Grid>
                <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="1">
                                <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="5">
                                    <ItemsControl ItemsSource="{Binding TempDatas}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" Margin="2,0,0,0" Foreground="{Binding ChannelColor}" VerticalAlignment="Center"/>
                                                    <ToggleButton Uid="{Binding Name}" Margin="1,0,0,0" Height="20" IsChecked="{Binding Show}" Style="{StaticResource ToggleButtonSwitch}" Command="{Binding DGToggle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,5,0">
                                    <TextBlock Text="ALL " FontSize="18" Margin="5,0,0,0" FontWeight="DemiBold" Foreground="Black" VerticalAlignment="Center"/>
                                    <ToggleButton Margin="2,0,0,0" Height="26" Style="{StaticResource ToggleButtonSwitch}" IsChecked="True"  Click="ToggleChAll_Click"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" Content="AutoFit" FontSize="18" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="40" Width="90"  HorizontalAlignment="Center"  VerticalAlignment="Center" RenderTransformOrigin="0.535,0.65"/>
                            </Grid>
                        </Grid>
                        <sp:WpfPlot Grid.Column="1" x:Name="xTempGraph"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
