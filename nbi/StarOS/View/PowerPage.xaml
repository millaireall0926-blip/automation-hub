<Page x:Class="StarOS.View.PowerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarOS.View"
      xmlns:vm="clr-namespace:StarOS.ViewModel"
      xmlns:model="clr-namespace:StarOS.Model"
      mc:Ignorable="d" 
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:hc="https://handyorg.github.io/handycontrol"         
      
      Title="PowerPage">

    <Page.DataContext>
        <vm:PowerVM/>
    </Page.DataContext>
    <Page.Resources>
        <model:DPSModel x:Key="xDPS1"/>
        <model:DPSModel x:Key="xDPS2"/>
        <model:DPSModel x:Key="xDPS3"/>
        <model:DPSModel x:Key="xDPS4"/>
        <model:DPSModel x:Key="xDPS5"/>
        <model:PEModel x:Key="xPE_VIH"/>
        <model:PEModel x:Key="xPE_VIL"/>
        <model:PEModel x:Key="xPE_VTH"/>
    </Page.Resources>

    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="41" Margin="10,0,0,0"  VerticalAlignment="Top" Width="45">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Offset="0"/>
                    <GradientStop Color="#77BBBBBB" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="/Resource/power.png" HorizontalAlignment="Left" Height="32" Margin="16,1,0,0" VerticalAlignment="Top" Width="35"/>
        <TextBlock HorizontalAlignment="Left" Height="47" TextWrapping="Wrap" VerticalAlignment="Top" Width="126" Margin="63,1,0,0" Text="POWER" Foreground="#FFFDFAFA" FontSize="24"/>
        <ToggleButton Content="AutoFit" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="30" Width="60"  HorizontalAlignment="Left" Margin="299,0,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.535,0.65"/>

        <ToolBar Header="DPS1" Margin="10,42,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="{Binding Source={StaticResource xDPS1}, Path=ColorV}" FontFamily="Courier New">
            <ToggleButton Margin="0,2,0,2" IsChecked="{Binding Source={StaticResource xDPS1}, Path=Show}" Style="{StaticResource ToggleButtonSwitch}" Click="ToggleButton_Click"/>
            <hc:Shield Margin="5,0,0,0" Subject="V" Status="{Binding Source={StaticResource xDPS1}, Path=GetV}" Color="{Binding Source={StaticResource xDPS1}, Path=ColorV}"/>
            <hc:Shield Margin="5,0,0,0" Subject="C" Status="{Binding Source={StaticResource xDPS1}, Path=GetC}" Color="{Binding Source={StaticResource xDPS1}, Path=ColorC}"/>
            <hc:Shield Margin="5,0,0,0" Subject="S" Status="{Binding Source={StaticResource xDPS1}, Path=SetV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="O" Status="{Binding Source={StaticResource xDPS1}, Path=OC}" Color="#FF3F3F46"/>
        </ToolBar>

        <ToolBar Header="DPS2" Margin="10,63,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="{Binding Source={StaticResource xDPS2}, Path=ColorV}" FontFamily="Courier New">
            <ToggleButton Margin="0,2,0,2" IsChecked="{Binding Source={StaticResource xDPS2}, Path=Show}" Style="{StaticResource ToggleButtonSwitch}" Click="ToggleButton_Click"/>
            <hc:Shield Margin="5,0,0,0" Subject="V" Status="{Binding Source={StaticResource xDPS2}, Path=GetV}" Color="{Binding Source={StaticResource xDPS2}, Path=ColorV}"/>
            <hc:Shield Margin="5,0,0,0" Subject="C" Status="{Binding Source={StaticResource xDPS2}, Path=GetC}" Color="{Binding Source={StaticResource xDPS2}, Path=ColorC}"/>
            <hc:Shield Margin="5,0,0,0" Subject="S" Status="{Binding Source={StaticResource xDPS2}, Path=SetV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="O" Status="{Binding Source={StaticResource xDPS2}, Path=OC}" Color="#FF3F3F46"/>
        </ToolBar>
        <ToolBar Header="DPS3" Margin="10,84,145,0" hc:ThemeManager.RequestedTheme="Dark" Height="20 " VerticalAlignment="Top" 
                 Foreground="{Binding Source={StaticResource xDPS3}, Path=ColorV}" FontFamily="Courier New">
            <ToggleButton Margin="0,2,0,2" IsChecked="{Binding Source={StaticResource xDPS3}, Path=Show}" Style="{StaticResource ToggleButtonSwitch}" Click="ToggleButton_Click"/>
            <hc:Shield Margin="5,0,0,0" Subject="V" Status="{Binding Source={StaticResource xDPS3}, Path=GetV}" Color="{Binding Source={StaticResource xDPS3}, Path=ColorV}"/>
            <hc:Shield Margin="5,0,0,0" Subject="C" Status="{Binding Source={StaticResource xDPS3}, Path=GetC}" Color="{Binding Source={StaticResource xDPS3}, Path=ColorC}"/>
            <hc:Shield Margin="5,0,0,0" Subject="S" Status="{Binding Source={StaticResource xDPS3}, Path=SetV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="O" Status="{Binding Source={StaticResource xDPS3}, Path=OC}" Color="#FF3F3F46"/>
        </ToolBar>

        <ToolBar Header="DPS4" Margin="10,105,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="{Binding Source={StaticResource xDPS4}, Path=ColorV}" FontFamily="Courier New">
            <ToggleButton Margin="0,2,0,2" IsChecked="{Binding Source={StaticResource xDPS4}, Path=Show}" Style="{StaticResource ToggleButtonSwitch}" Click="ToggleButton_Click"/>
            <hc:Shield Margin="5,0,0,0" Subject="V" Status="{Binding Source={StaticResource xDPS4}, Path=GetV}" Color="{Binding Source={StaticResource xDPS4}, Path=ColorV}"/>
            <hc:Shield Margin="5,0,0,0" Subject="C" Status="{Binding Source={StaticResource xDPS4}, Path=GetC}" Color="{Binding Source={StaticResource xDPS4}, Path=ColorC}"/>
            <hc:Shield Margin="5,0,0,0" Subject="S" Status="{Binding Source={StaticResource xDPS4}, Path=SetV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="O" Status="{Binding Source={StaticResource xDPS4}, Path=OC}" Color="#FF3F3F46"/>
        </ToolBar>

        <ToolBar Header="DPS5" Margin="10,126,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark"
                 Foreground="{Binding Source={StaticResource xDPS5}, Path=ColorV}" FontFamily="Courier New">
            <ToggleButton Margin="0,2,0,2" IsChecked="{Binding Source={StaticResource xDPS5}, Path=Show}" Style="{StaticResource ToggleButtonSwitch}" Click="ToggleButton_Click"/>
            <hc:Shield Margin="5,0,0,0" Subject="V" Status="{Binding Source={StaticResource xDPS5}, Path=GetV}" Color="{Binding Source={StaticResource xDPS5}, Path=ColorV}"/>
            <hc:Shield Margin="5,0,0,0" Subject="C" Status="{Binding Source={StaticResource xDPS5}, Path=GetC}" Color="{Binding Source={StaticResource xDPS5}, Path=ColorC}"/>
            <hc:Shield Margin="5,0,0,0" Subject="S" Status="{Binding Source={StaticResource xDPS5}, Path=SetV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="O" Status="{Binding Source={StaticResource xDPS5}, Path=OC}" Color="#FF3F3F46"/>
        </ToolBar>


        <ToolBar Header="VIH  " Margin="10,150,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="White" FontFamily="Courier New" >
            <hc:Shield Margin="5,0,0,0" Subject="IO" Status="{Binding Source={StaticResource xPE_VIH}, Path=IOV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="CK" Status="{Binding Source={StaticResource xPE_VIH}, Path=CLKV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="DR" Status="{Binding Source={StaticResource xPE_VIH}, Path=DRV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="SC" Status="{Binding Source={StaticResource xPE_VIH}, Path=ScanV}" Color="#FF3F3F46"/>
        </ToolBar>
        <ToolBar Header="VIL  " Margin="10,171,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="White" FontFamily="Courier New" >
            <hc:Shield Margin="5,0,0,0" Subject="IO" Status="{Binding Source={StaticResource xPE_VIL}, Path=IOV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="CK" Status="{Binding Source={StaticResource xPE_VIL}, Path=CLKV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="DR" Status="{Binding Source={StaticResource xPE_VIL}, Path=DRV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="SC" Status="{Binding Source={StaticResource xPE_VIL}, Path=ScanV}" Color="#FF3F3F46"/>
        </ToolBar>
        <ToolBar Header="VTH  " Margin="10,192,145,0" Height="20" VerticalAlignment="Top" hc:ThemeManager.RequestedTheme="Dark" 
                 Foreground="White" FontFamily="Courier New" >
            <hc:Shield Margin="5,0,0,0" Subject="IO" Status="{Binding Source={StaticResource xPE_VTH}, Path=IOV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="CK" Status="{Binding Source={StaticResource xPE_VTH}, Path=CLKV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="DR" Status="{Binding Source={StaticResource xPE_VTH}, Path=DRV}" Color="#FF3F3F46"/>
            <hc:Shield Margin="5,0,0,0" Subject="SC" Status="{Binding Source={StaticResource xPE_VTH}, Path=ScanV}" Color="#FF3F3F46"/>
        </ToolBar>

        <sp:WpfPlot x:Name="xPowerGraph" Margin="360,0,0,0" />




    </Grid>

</Page>
