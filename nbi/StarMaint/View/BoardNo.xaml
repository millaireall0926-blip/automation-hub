<Page x:Class="StarMaint.View.BoardNo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarMaint.View"
      xmlns:vm="clr-namespace:StarMaint.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="#FF202050"
      Title="BoardNo" Loaded="Page_Loaded">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Rectangle StrokeThickness="10" Fill="#00000000" 
                       Stroke="#FF303030" RadiusX="10" RadiusY="10"
                       />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="TPBC Board Serial Number"
                       Foreground="SteelBlue"
                       VerticalAlignment="Center"
                       FontSize="20" Margin="20"/>
                <TextBox Background="#FF505050" Foreground="AntiqueWhite"
                         BorderThickness="2" Margin="12" MinWidth="200"
                         FontSize="20" VerticalAlignment="Center" 
                         Text="{Binding Tpcbno}" IsReadOnly="{Binding IsLock}" />


            </StackPanel>
        </Grid>
        <ItemsControl ItemsSource="{Binding DpsDatas}" Margin="0,70,0,6" Grid.RowSpan="2" >
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" Background="#FF202030" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:DpsNo />
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" 
                    x:Name="xBT_Lock"
                        Style="{StaticResource TooltipButton}"
                        Content="Lock"
                        ToolTip="Lock/Unlock"
                        Background="#c82131"
                        BorderBrush="#d53342"
                        Margin="10,0,10,0" 
                        Command="{x:Static vm:MainVM.SerialNoCmd}" Height="70" VerticalAlignment="Top" 
                    />

            <Button Grid.Column="2" Style="{StaticResource TooltipButton}"
                    x:Name="xBT_Push"
                    Content="Push"
                    ToolTip="Write Board Serial"
                    Background="#149331"
                    BorderBrush="#26a142"
                    Margin="10,0,10,0" 
                    Command="{x:Static vm:MainVM.SerialNoCmd}" Cursor="Hand" 
                    />
        </Grid>
    </Grid>
</Page>
