<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarQMOS.View"
        xmlns:hc="https://handyorg.github.io/handycontrol" x:Class="StarQMOS.View.ChamCTRL"
        mc:Ignorable="d"
        Title="ChamCTRL" Height="800" Width="636" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" KeyDown="Window_KeyDown" Topmost="True">
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="721"  Stroke="Black" VerticalAlignment="Top" Width="541" Margin="28,31,0,0" RadiusX="35.872" RadiusY="35.872"
                   MouseDown="Rectangle_MouseDown">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#EEE86640"/>
                    <GradientStop Color="#EE692B22" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image MouseDown="Rectangle_MouseDown" Source="/Resource/cmdcham.png" HorizontalAlignment="Left" Height="42" Margin="52,23,0,0" VerticalAlignment="Top"  Width="53"/>
        <TextBlock MouseDown="Rectangle_MouseDown" HorizontalAlignment="Left" Height="29" TextWrapping="Wrap" Text="CHAMBER CONTROL" VerticalAlignment="Top" Width="179" FontSize="18" Foreground="#FFFDF3F3" Margin="99,36,0,0"/>
        <TextBlock Text="{Binding CurPLC.Name}" MouseDown="Rectangle_MouseDown" HorizontalAlignment="Left" Height="29" TextWrapping="Wrap" VerticalAlignment="Top" Width="179" FontSize="18" Foreground="#FFFDF3F3" Margin="284,36,0,0"/>

        <hc:Card Content="CHAMBER MODE" HorizontalAlignment="Left" Height="121" VerticalAlignment="Top" Width="515" Margin="37,70,0,0" Background="#EE9E472E"/>

        <Button x:Name="xBTClose" Background="Transparent" BorderThickness="0" Click="xBTClose_Click" HorizontalAlignment="Left" Margin="514,32,0,0" VerticalAlignment="Top">
            <Image Source="/Resource/close.png" />
        </Button>
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="47,103,0,0" TextWrapping="Wrap" Text="CHAMBER STAT" VerticalAlignment="Top" Width="112" FontSize="14" />
        <TextBlock HorizontalAlignment="Left" Height="23" Margin="179,103,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="112" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.Stat}" Value="0">
                            <Setter Property="Foreground" Value="DarkGray"/>
                            <Setter Property="Text" Value="DISCONNECT"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Stat}" Value="1">
                            <Setter Property="Foreground" Value="#FF60A221"/>
                            <Setter Property="Text" Value="RUN"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Stat}" Value="4">
                            <Setter Property="Foreground" Value="#FF2047A5"/>
                            <Setter Property="Text" Value="STOP"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Stat}" Value="2">
                            <Setter Property="Foreground" Value="#FFC7C131"/>
                            <Setter Property="Text" Value="AMBIENT"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>

        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="179,148,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="112" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.Remote}" Value="0">
                            <Setter Property="Text" Value="Remote"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Remote}" Value="1">
                            <Setter Property="Text" Value="Local"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>

        <Button Click="Button_Click" Content="RUN" HorizontalAlignment="Left" Height="36" Margin="317,95,0,0" VerticalAlignment="Top" Width="70" Background="#FF60A221"/>
        <Button Click="Button_Click" Content="STOP" HorizontalAlignment="Left" Height="36" Margin="393,95,0,0" VerticalAlignment="Top" Width="70" Background="#FF2047A5"/>
        <Button Click="Button_Click" Content="AMBIENT" HorizontalAlignment="Left" Height="36" Margin="469,94,0,0" VerticalAlignment="Top" Width="70" Background="#FFC7C131"/>
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="47,211,0,0" TextWrapping="Wrap" Text="TARGET TEMP" VerticalAlignment="Top" Width="112" FontSize="14" />
        <TextBox Text="{Binding SetTemp}" Background="Transparent" HorizontalAlignment="Left" Height="30" Margin="178,208,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="67" FontSize="16" />
        <TextBlock Text="CURRENT TEMP" Foreground="White" HorizontalAlignment="Left" Height="23" Margin="47,250,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="112" FontSize="14" />

        <TextBlock Text="{Binding CurPLC.CurTemp, StringFormat=\{0:F1\} ℃}" Foreground="White" HorizontalAlignment="Left" Height="23" Margin="179,251,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="112" FontSize="16" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="47,149,0,0" TextWrapping="Wrap" Text="REMOTE MODE" VerticalAlignment="Top" Width="112" FontSize="14" />


        <Button Click="Button_Click" Content="REMOTE" HorizontalAlignment="Left" Height="36" Margin="317,139,0,0" VerticalAlignment="Top" Width="70"/>
        <Button Click="Button_Click" Content="SET" HorizontalAlignment="Left" Height="36" Margin="317,205,0,0" VerticalAlignment="Top" Width="70"/>
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="48,304,0,0" TextWrapping="Wrap" Text="RACK STAT" VerticalAlignment="Top" Width="112" FontSize="14" />


        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="179,339,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="112" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.Door}" Value="0">
                            <Setter Property="Text" Value="OPEN"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Door}" Value="1">
                            <Setter Property="Text" Value="CLOSE"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Door}" Value="2">
                            <Setter Property="Text" Value="NO INFO"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>

        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="179,305,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="112" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.Rack}" Value="0">
                            <Setter Property="Text" Value="REMOVE"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.Rack}" Value="1">
                            <Setter Property="Text" Value="INSERT"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>


        <Button Click="Button_Click" Content="IN" HorizontalAlignment="Left" Height="36" Margin="318,294,0,0" VerticalAlignment="Top" Width="70"/>
        <Button Click="Button_Click" Content="OUT" HorizontalAlignment="Left" Height="36" Margin="393,294,0,0" VerticalAlignment="Top" Width="70" RenderTransformOrigin="0.943,0.556"/>
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="48,339,0,0" TextWrapping="Wrap" Text="DOOR STAT" VerticalAlignment="Top" Width="112" FontSize="14" />

        <Button Click="Button_Click" Content="OPEN" HorizontalAlignment="Left" Height="36" Margin="318,332,0,0" VerticalAlignment="Top" Width="70"/>
        <Button Click="Button_Click" Content="CLOSE" HorizontalAlignment="Left" Height="36" Margin="393,332,0,0" VerticalAlignment="Top" Width="70" RenderTransformOrigin="0.943,0.556"/>

        <hc:Card Content="LAMP MODE" HorizontalAlignment="Left" Height="146" VerticalAlignment="Top" Width="515" Margin="37,382,0,0" Background="#EE924E3B"/>

        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="47,405,0,0" TextWrapping="Wrap" Text="LAMP STAT" VerticalAlignment="Top" Width="112" FontSize="14" />
        <TextBlock Text="{Binding CurPLC.LampStat, StringFormat=0X{0:X8}}" Foreground="White" HorizontalAlignment="Left" Height="23" Margin="178,405,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="112" FontSize="14" RenderTransformOrigin="0.312,0.522" />

        <Button Click="Button_Click" Content="RED" HorizontalAlignment="Left" Height="36" Margin="317,398,0,0" VerticalAlignment="Top" Width="70" Foreground="#FFF50D0D"/>
        <Button Click="Button_Click" Content="YELLOW" HorizontalAlignment="Left" Height="36" Margin="393,398,0,0" VerticalAlignment="Top" Width="70" Foreground="#FFF3EA04"/>
        <Button Click="Button_Click" Content="GREEN" HorizontalAlignment="Left" Height="36" Margin="469,398,0,0" VerticalAlignment="Top" Width="70" Foreground="#FF13F90B"/>
        <Button Click="Button_Click" Content="RBLINK" HorizontalAlignment="Left" Height="36" Margin="317,439,0,0" VerticalAlignment="Top" Width="70" Foreground="#FFF50D0D"/>
        <Button Click="Button_Click" Content="YBLINK" HorizontalAlignment="Left" Height="36" Margin="393,439,0,0" VerticalAlignment="Top" Width="70" Foreground="#FFF3EA04"/>
        <Button Click="Button_Click" Content="GBLINK" HorizontalAlignment="Left" Height="36" Margin="469,439,0,0" VerticalAlignment="Top" Width="70" Foreground="#FF13F90B"/>
        <Button Click="Button_Click" Content="BUZZER" HorizontalAlignment="Left" Height="36" Margin="469,480,0,0" VerticalAlignment="Top" Width="70"/>
        <Button Click="Button_Click" Content="OWNER" HorizontalAlignment="Left" Height="36" Margin="48,481,0,0" VerticalAlignment="Top" Width="70"/>
        <Button Click="Button_Click" Content="CTRL" Height="36" Margin="208,482,0,0" VerticalAlignment="Top" Width="70" HorizontalAlignment="Left" />
        <TextBlock Foreground="#FFFF0606" HorizontalAlignment="Left" Height="13" Margin="47,426,0,0" TextWrapping="Wrap" Text="Red     : 0x0001        Blink:0x0010" VerticalAlignment="Top" Width="220" FontSize="10" />
        <TextBlock Foreground="#FFF9FB06" HorizontalAlignment="Left" Height="13" Margin="48,439,0,0" TextWrapping="Wrap" Text="Yellow : 0x0002        Blink:0x0020" VerticalAlignment="Top" Width="220" FontSize="10" />
        <TextBlock Foreground="#FF3CFB09" HorizontalAlignment="Left" Height="13" Margin="47,453,0,0" TextWrapping="Wrap" Text="Green  : 0x0004        Blink:0x0040" VerticalAlignment="Top" Width="220" FontSize="10" />
        <TextBlock Foreground="#FFF7F7F7" HorizontalAlignment="Left" Height="13" Margin="225,426,0,0" TextWrapping="Wrap" Text="Buzzer : 0x0100" VerticalAlignment="Top" Width="77" FontSize="10" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="123,488,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="75" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.LampOwn}" Value="0">
                            <Setter Property="Text" Value="PLC OWN"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.LampOwn}" Value="1">
                            <Setter Property="Text" Value="OS OWN"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>

        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="281,488,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="71" FontSize="14" >
            <TextBlock.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurPLC.LampCtrl}" Value="0">
                            <Setter Property="Text" Value="Menual"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurPLC.LampCtrl}" Value="1">
                            <Setter Property="Text" Value="Flow"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>

        <hc:Card Content="ALARM (D80 ~ D87)" HorizontalAlignment="Left" Height="186" VerticalAlignment="Top" Width="515" Margin="37,540,0,0" Background="#EE8E322D"/>
        <ListView Margin="48,565,100,87" ItemsSource="{Binding CurPLC.Alarms}" Background="#FF653320" BorderBrush="#FF885633" >
            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </ListView.Resources>
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}" >
                    <Setter Property="Background" Value="#FF9E392F" />
                    <Setter Property="FontFamily" Value="Courier New" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="300" Header="Search Term" DisplayMemberBinding="{Binding StringFormat=0X{0:X8}}" />
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" Text="℃" VerticalAlignment="Top" Width="23" Margin="252,210,0,0" FontSize="16" Foreground="White"/>


        <!--TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="48,574,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="318,574,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="48,598,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="317,598,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="50,621,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="317,621,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" />
        <TextBlock Foreground="White" HorizontalAlignment="Left" Height="23" Margin="50,644,0,0" TextWrapping="Wrap" Text="LAMP VALUE" VerticalAlignment="Top" Width="218" FontSize="14" /-->


    </Grid>
</Window>
