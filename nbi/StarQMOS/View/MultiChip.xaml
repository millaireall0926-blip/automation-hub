<Window x:Class="StarQMOS.View.MultiChip"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarQMOS.View"
        mc:Ignorable="d"
        Title="LotInfo" Height="360" Width="360"
        xmlns:hc="https://handyorg.github.io/handycontrol" 
        AllowsTransparency="True" WindowStyle="None" Background="{x:Null}" 
        KeyDown="Window_KeyDown" Topmost="True">
    <Grid >
        <Image MouseDown="Image_MouseDown" Source="/Resource/multichip.png" HorizontalAlignment="Left" VerticalAlignment="Center" />
        <Ellipse  MouseDown="Image_MouseDown" HorizontalAlignment="Left" Height="245" Margin="95,20,0,0"  VerticalAlignment="Top" Width="244">
            <Ellipse.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#55A5C9EA"/>
                    <GradientStop Color="#DD0A253E" Offset="1"/>
                </LinearGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Button x:Name="xBTClose" Margin="0,34,0,0" Background="Transparent" BorderThickness="0" Click="xBTClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Height="30" Width="48" >
            <Image Source="/Resource/close.png" />
        </Button>
        <Grid Margin="145,34,65,97">
            <ItemsControl ItemsSource="{Binding MCDutModels}" FontSize="10" Margin="0,-23,0,-14"  >
                <ItemsControl.ItemsPanel >
                    <ItemsPanelTemplate>
                        <Canvas x:Name="xCanvas" SizeChanged="xCanvas_SizeChanged" Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="{Binding Width}" Height="{Binding Height}"                                 
                                BorderThickness="2" BorderBrush="#FF303030" Foreground="Black"                          
                                FontSize="10"
                                Background="{Binding Color}"                                      
                                Content="{Binding Text}"
                                ToolTip="{Binding Text}"             
                                Uid="{Binding Num}"
                                Click="Button_Click"
                                ToolTipService.ShowOnDisabled="False"
                                VerticalAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold"                                
                                >
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4" />
                                </Style>
                                <Style TargetType="Button">
                                </Style>

                            </Button.Resources>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

    </Grid>
</Window>
