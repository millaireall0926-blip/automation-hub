<Page x:Class="StarResult.View.PowerGraph"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarResult.View"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:vm="clr-namespace:StarResult.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PowerGraph">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Background="CadetBlue">
                <TextBox Text="Level    " Background="CadetBlue" Foreground="WhiteSmoke" FontWeight="Bold" BorderThickness="0"/>
                <CheckBox x:Name="xCB_vps1" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click">PS1</CheckBox>
                <CheckBox x:Name="xCB_vps2" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click">PS2</CheckBox>
                <CheckBox x:Name="xCB_vps3" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click">PS3</CheckBox>
                <CheckBox x:Name="xCB_vps4" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click">PS4</CheckBox>
                <CheckBox x:Name="xCB_vps5" Checked="CheckBox_Click" Unchecked="CheckBox_Click">PS5</CheckBox>
                <CheckBox x:Name="xCB_io"    Checked="CheckBox_Click" Unchecked="CheckBox_Click">IO</CheckBox>
                <CheckBox x:Name="xCB_clk"  Checked="CheckBox_Click" Unchecked="CheckBox_Click">CLK</CheckBox>
                <CheckBox x:Name="xCB_drv"  Checked="CheckBox_Click" Unchecked="CheckBox_Click">DRV</CheckBox>
                <CheckBox x:Name="xCB_scan" Checked="CheckBox_Click" Unchecked="CheckBox_Click">Scan</CheckBox>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="SteelBlue">
                <TextBox Text="Current " Background="SteelBlue" Foreground="WhiteSmoke" FontWeight="Bold" BorderThickness="0" VerticalAlignment="Top"/>
                <CheckBox x:Name="xCB_cps1" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click" VerticalAlignment="Center">PS1</CheckBox>
                <CheckBox x:Name="xCB_cps2" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click" VerticalAlignment="Center">PS2</CheckBox>
                <CheckBox x:Name="xCB_cps3" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click" VerticalAlignment="Center">PS3</CheckBox>
                <CheckBox x:Name="xCB_cps4" IsChecked="True" Checked="CheckBox_Click" Unchecked="CheckBox_Click" VerticalAlignment="Center">PS4</CheckBox>
                <CheckBox x:Name="xCB_cps5"  Checked="CheckBox_Click" Unchecked="CheckBox_Click"  VerticalAlignment="Center">PS5</CheckBox>
            </StackPanel>
            <CheckBox x:Name="xCB_show" Grid.Row="1" HorizontalAlignment="Right"  Checked="CheckBox_Click" Unchecked="CheckBox_Click">Show Type</CheckBox>

        </Grid>
        <sp:WpfPlot Grid.Row="1" x:Name="xPowerGraph" />
    </Grid>
</Page>
