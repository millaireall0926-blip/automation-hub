<Page x:Class="StarResult.View.ResultSelection"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarResult.View"
      xmlns:vm="clr-namespace:StarResult.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"     
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="500"
      Title="ResultSelection">
    <Page.DataContext>
        <vm:ResultSectionVM />
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="4" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="RESULT SELECTION" FontSize="30" FontWeight="Bold" Margin="40,0,0,0"/>
        <Rectangle Grid.Row="1" Fill="#FF331616" Margin="10, 0,10,0"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="290" />
                    <RowDefinition Height="3" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <!--hc:SearchBar Text="{Binding SelBID}" hc:InfoElement.Title="BIB     " hc:InfoElement.Necessary="True"
                              hc:InfoElement.Placeholder="Please Input BID" Margin="0,0,0,0" Style="{StaticResource SearchBarExtend}"/-->
                    <TextBlock Text="LOTID / DATE Searching" FontSize="12" Margin="6, 4, 0, 0" />
                    <TextBlock Text="Is Base On Slot Selection" FontSize="12" Margin="10, 1, 0, 5" />
                    <hc:SearchBar Text="{Binding SelLotID}" hc:InfoElement.Title="LOT ID" hc:InfoElement.Necessary="True" FontWeight="Bold"
                              hc:InfoElement.Placeholder="Please Input LOT ID" Margin="0,0,0,0" Style="{StaticResource SearchBarExtend}" 
                                  Command="{Binding FindCmd}" CommandParameter="1"/>
                    <hc:DatePicker hc:InfoElement.TitleWidth="140" Margin="0,20,0,0" FontWeight="Bold"
                                   hc:InfoElement.Placeholder="Please enter the content"
                                   hc:InfoElement.Title="DATE FROM" SelectedDate="{Binding SelFrom}"/>
                    <hc:DatePicker hc:InfoElement.TitleWidth="140" 
                                   hc:InfoElement.Placeholder="Please enter the content" FontWeight="Bold"
                                   hc:InfoElement.Title="DATE TO" SelectedDate="{Binding SelTo}"/>
                    <Button Margin="0,10,0,0" Content="Search By Time" HorizontalAlignment="Right"
                            Command="{Binding FindCmd}" CommandParameter="2">
                        
                    </Button>
                </StackPanel>
                <GridSplitter Grid.Row="1"  HorizontalAlignment="Stretch" Background="WhiteSmoke" />
                <DataGrid Grid.Row="2" x:Name="SlotGrid" Margin="0"         
                  CanUserAddRows="False"
                  AutoGenerateColumns = "False"
                  CanUserResizeRows="True"      
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  ItemsSource="{Binding Slots}"  MouseUp="SlotGrid_MouseUp"
                  >
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderThickness" Value="3" />
                                    <Setter Property="BorderBrush" Value="IndianRed" />
                                    <Setter Property="Background" Value="#FF863B3B" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Slot" Width="*" IsReadOnly="True"  >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Background="{Binding Statbr}" 
                                               TextAlignment="Center" VerticalAlignment="Center" 
                                               FontSize="10" FontFamily="Fixedsys" FontWeight="Bold" Padding="10"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
            <GridSplitter Grid.Column="1"  HorizontalAlignment="Stretch" Background="WhiteSmoke" />
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="xSP_File"/>
            </ScrollViewer>




        </Grid>
        <Image HorizontalAlignment="Left" Height="18" Margin="20,6,0,0" VerticalAlignment="Top" Width="21" Source="/Resource/starResult.ico"/>
    </Grid>
</Page>
