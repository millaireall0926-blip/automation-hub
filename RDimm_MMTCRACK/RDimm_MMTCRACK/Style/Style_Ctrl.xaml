<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="xsTitleGrid" TargetType="{x:Type Grid}">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True" >
                <Setter Property="Background" Value="#AAAAAAAA"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="False" >
                <Setter Property="Background" Value="#00000000"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="datagridcellaligncenter" TargetType="DataGridCell">
        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
        <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="datagridheaderaligncenter" TargetType="DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>