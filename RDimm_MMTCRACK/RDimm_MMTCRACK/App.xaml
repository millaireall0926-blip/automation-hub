<Application x:Class="RDimm_MMTCRACK.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RDimm_MMTCRACK"
             StartupUri="MainWindow.xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:ThemeResources RequestedTheme="Light"/>
                <hc:Theme/>

                <ResourceDictionary Source="pack://application:,,,/handycontrol;component/Themes/Theme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/RDimm_MMTCRACK;component/Style/Style_Ctrl.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
