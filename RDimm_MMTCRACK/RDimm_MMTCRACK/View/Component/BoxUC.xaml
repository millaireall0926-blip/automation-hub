<UserControl x:Class="RDimm_MMTCRACK.View.Component.BoxUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RDimm_MMTCRACK.View.Component"
             xmlns:hc="https://handyorg.github.io/handycontrol" 
             xmlns:uc="clr-namespace:RDimm_MMTCRACK.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="150">
    <Grid Margin="3">
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" Background="{Binding BoxColor}" BorderBrush="{Binding BoarderColor}">
            <Grid  Margin="-10" Background="{Binding BoxColor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="23"/>
                    <RowDefinition Height="23"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="23"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.ColumnSpan="2" FontWeight="DemiBold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Run Text=" Box "/>
                    <Run Text="{Binding BoxViewIndex}"/>
                </TextBlock>
                <CheckBox Grid.Row="1" Content="TC Unit" IsChecked="{Binding IsBoxTCUnit}" Margin="3,0,0,0"/>
                <CheckBox Grid.Row="1" Grid.Column="1" Content="AS" IsChecked="{Binding IsBoxAS}" Margin="0,0,5,0" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="2" Content="TAMS" Margin="3,0,0,0" IsChecked="{Binding ISBoxTams}" IsEnabled="{Binding IsBoxTamsEnable}"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock VerticalAlignment="Center" Text="습도 " FontSize="12" Margin="15,0,0,0" FontWeight="DemiBold"/>
                    <TextBlock Text="{Binding HumidityValue}" FontSize="12" VerticalAlignment="Center" Foreground="{Binding HumRateColor}" FontWeight="DemiBold"/>
                </StackPanel>
                <TextBlock Grid.Row="3" Text="SV " FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,0,0,0" FontSize="24"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BoxSetSV, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnlySV}" 
                         Width="60" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="24">
                    <TextBox.InputBindings>
                        <KeyBinding Command="{Binding BoxCmdSetTemp}" Key="Enter" />
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Grid.Row="4" Text="PV " FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,0,0,0" FontSize="24"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding BoxPVText}" FontWeight="DemiBold" VerticalAlignment="Center" 
                           HorizontalAlignment="Center" Foreground="{Binding BoxPVColor}" Margin="0" FontSize="24"/>
                <!-- SV value Binding Here -->
                <Grid Grid.Row="5" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding BoxStatText}" Margin="1,0,0,0" BorderThickness="0" Background="Transparent" FontWeight="DemiBold" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Label Grid.Column="1" Content="{Binding DefostTime}" Margin="0,0,1,0" BorderThickness="0" Background="Transparent" FontWeight="DemiBold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="3" Grid.RowSpan="3" Grid.ColumnSpan="2" Visibility="{Binding BoxShowBox}">
                    <Rectangle x:Name="xRectMeg" Fill="{Binding BoxMsgColor}"/>
                    <TextBlock Text="{Binding BoxMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" FontFamily="굴림" FontWeight="DemiBold"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>