<UserControl x:Class="RDimm_MMTCRACK.View.Component.RackUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RDimm_MMTCRACK.View.Component"
             xmlns:uc="clr-namespace:RDimm_MMTCRACK.View.Component"
             xmlns:hc="https://handyorg.github.io/handycontrol"  
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="450">
    <Grid Margin="1">
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" BorderBrush="{Binding BoarderColor}" >
            <Grid Background="{Binding RackColor}" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.18*" />
                    <RowDefinition Height="0.25*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="5,2,0,2">
                    <!-- Check Box Area -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="DemiBold" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Run Text="FIX " />
                        <Run Text="{Binding RackViewIndex}"/>
                    </TextBlock>
                    <CheckBox Grid.Column="1" Content="TC Unit" Margin="5,0,0,0" IsChecked="{Binding IsRackTCUnit}" />
                    <CheckBox Grid.Column="2" Content="TAMS" IsChecked="{Binding IsRackTams}" IsEnabled="{Binding IsRackTamsEnable}"/>
                    <Button Grid.Column="3" Padding="1,1" Content="UP" Height="23" Width="60" Command="{Binding RackManualUp}" Visibility="{Binding RackEngrmodeVisibility}"/>
                    <Button Grid.Column="4" Padding="1,1" Content="DOWN" Height="23" Width="60" Command="{Binding RackManualDown}" Visibility="{Binding RackEngrmodeVisibility}"/>
                    <CheckBox Grid.Column="5" Content="AS" HorizontalAlignment="Right" Margin="0,0,10,0" IsChecked="{Binding IsRackAS}"/>
                </Grid>
                <Grid Grid.Row="1">
                    <!-- Name SV PV Area -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="0.85*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- <Label Grid.Column="1" Content="{Binding RemainDefosrtTime}" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" FontWeight="DemiBold"/> -->
                    <Button Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="11" FontWeight="DemiBold" Padding="1,1" Height="33" Width="65" Command="{Binding RackPopUpClear}" Visibility="Visible">
                        <TextBlock TextAlignment="Center">
                        <Run Text="Fix" />
                        <Run Text="{Binding RackViewIndex}"/>
                        <LineBreak/>
                        <Run Text="Clear 팝업"/>
                        </TextBlock>
                    </Button>

                    <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" FontWeight="DemiBold" Padding="1,1" Height="33" Width="75" Command="{Binding RackStatToggle}" Visibility="Hidden">
                        <TextBlock TextAlignment="Center">
                            <Run Text="RackStat"/>
                            <LineBreak/>
                            <Run Text="Toggle"/>
                        </TextBlock>
                    </Button>


                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock VerticalAlignment="Center" Text="SV" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtSV" Width="50" Height="25"  Margin="0,0,0,3" Text="{Binding RackSetSV, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsEnabled="{Binding EnableSV}" >
                            <TextBox.InputBindings>
                                <KeyBinding Command="{Binding DGCmdSetTemp}" Key="Enter"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock VerticalAlignment="Center" Text="℃" Margin="5,0,10,0"/>
                        <TextBlock VerticalAlignment="Center" Text="PV(MAX)" Margin="0,0,5,0"/>
                        <TextBox Width="50" Height="25" Text="{Binding MaxPV}" Margin="0,0,0,3" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        <TextBlock VerticalAlignment="Center" Text="℃" Margin="5,0,10,0"/>
                    </StackPanel>

                </Grid>
                <Grid Grid.Row="2" Margin="3">
                    <!-- CBox Area-->
                    <ItemsControl ItemsSource="{Binding CBoxs}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <uc:CBoxUC/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                <Grid Grid.Row ="2" Visibility="{Binding ShowBox}">
                    <Rectangle Fill="{Binding RackMsgColor}"/>
                    <TextBlock Text="{Binding RackMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="굴림" FontWeight="Bold"></TextBlock>
                </Grid>
                <Grid Grid.Row ="2" Visibility="{Binding SlideShowBox}">
                    <Rectangle Fill="{Binding SlideMsgColor}"/>
                    <TextBlock Text="{Binding SlideMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="굴림" FontWeight="Bold"></TextBlock>
                </Grid>

                <Grid Grid.Row="3" Margin="5,0,0,0">
                    <!-- Run/Stop Area-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Run" Height="35" Width="68" Command="{Binding RackCmdRun}"/>
                    <Button Grid.Column="1" Content="Stop" Height="35" Width="68" Command="{Binding RackCmdStop}"/>
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2.5*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Content="{Binding RackStatText}" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Width="73" HorizontalAlignment="Center" FontSize="12" FontWeight="DemiBold"/>
                        <Label Grid.Row="1" Content="{Binding DefrostTime}" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Width="73" HorizontalAlignment="Center" FontSize="12" FontWeight="DemiBold"/>
                    </Grid>
                    
                    <TextBox Grid.Column="3" IsReadOnly="True" Height="35" Width="70" Text="{Binding MotorStatText}" Background="{Binding MotorStatColor}" FontSize="14" FontWeight="DemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" BorderBrush="Black"  Margin="0,0,0,0"/>
                    <Label Grid.Column="4" Background="Transparent" Content="{Binding FlowStatText}" Height="35" Width="85" Foreground="{Binding FlowStatColor}" FontSize="12" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" BorderThickness="0" />
                    <!-- <TextBox Grid.Column="3" IsReadOnly="True" Text="저유량 경고" FontSize="12" FontWeight="DemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="2" BorderBrush="Black" Background="{Binding BoarderColor}" Margin="5,0,5,0"/> -->
                    <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="12">
                        <Run Text="유량 " FontWeight="DemiBold"/>
                        <Run Text="{Binding FlowRate}" Foreground="{Binding FlowRateColor}" FontWeight="DemiBold"/>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
