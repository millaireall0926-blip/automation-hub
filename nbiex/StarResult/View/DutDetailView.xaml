<Page x:Class="StarResult.View.DutDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarResult.View"
      xmlns:vm="clr-namespace:StarResult.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"    
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DutDetailView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="DUT : " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
            <TextBlock Text="{Binding CurDno}" VerticalAlignment="Center" Width="100" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke"/>
            <TextBlock Text="TYPE : " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
            <TextBlock Text="{Binding SubType}" VerticalAlignment="Center" Width="240" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke"/>
            <TextBlock Text="COUNT : " VerticalAlignment="Center" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
            <TextBlock Text="{Binding SubItemCount}" VerticalAlignment="Center" Width="100" FontSize="18" Foreground="WhiteSmoke"/>
        </StackPanel>
        <ListBox x:Name="xListBlock" ItemsSource="{Binding SubBlockModels}" Grid.Row="1" Style="{DynamicResource WrapPanelHorizontalListBox}" Margin="10, 4, 10, 8" Visibility="{Binding ShowBlock}" Background="#FFD2ADAD">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" BorderBrush="PapayaWhip" Margin="2,2" CornerRadius="2">
                        <TextBlock Padding="2" Text="{Binding Block}" Foreground="MintCream" FontSize="12">
                            <TextBlock.Resources>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="0">
                                            <Setter Property="Background" Value="IndianRed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="1">
                                            <Setter Property="Background" Value="#FFED2F2F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="2">
                                            <Setter Property="Background" Value="DarkGray"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="3">
                                            <Setter Property="Background" Value="#FF4C4B4B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Resources>
                        </TextBlock>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Row="1" Visibility="{Binding ShowDetail}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="20*"/>
            </Grid.ColumnDefinitions>
            <ListView x:Name="xListView_Block" Grid.Column="0" Margin="10, 10, 0, 10" ItemsSource="{Binding SubFDetailBlocks}" Style="{StaticResource ListView.Small}" Visibility="{Binding ShowDetail}" Foreground="White" Background="#FF242469"
                           PreviewMouseLeftButtonUp="ListViewDetail_PreviewMouseLeftButtonUp" FontWeight="Bold">
                <ListView.View>
                    <GridView>
                        <GridViewColumn DisplayMemberBinding="{Binding Text}" Header="BLOCK" Width="300"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <ListView x:Name="xListView_Page" Grid.Column="1" FontSize="10" Margin="10, 10, 0, 10" ItemsSource="{Binding SubFDetailPages}" Visibility="{Binding ShowDetail}" Style="{StaticResource ListView.Small}" 
                      FontWeight="Bold" Foreground="White" Background="#FF154356"
                          PreviewMouseLeftButtonUp="ListViewDetail_PreviewMouseLeftButtonUp">
                <ListView.View>
                    <GridView>
                        <GridViewColumn DisplayMemberBinding="{Binding Text}" Header="PAGE" Width="300"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <ListBox Grid.Column="2" Margin="10" ItemsSource="{Binding SubFDetailCols}" Visibility="{Binding ShowDetail}" 
                     FontWeight="Bold" Foreground="AntiqueWhite" Background="#FF248069">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" FontSize="10" FontWeight="Bold"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <TextBox Grid.Row="3" Visibility="{Binding ShowBin}"  Text="{Binding BinText}"                     
                     AcceptsReturn="True" FontFamily="Courier New" FontSize="12" IsReadOnly="True"
                     VerticalScrollBarVisibility="Visible" Background="#FFDACCC8"/>
        <DataGrid Grid.Row="3" Visibility="{Binding ShowCycle}" ItemsSource="{Binding DT_Cycle}">
            <DataGrid.Resources>
                <Style TargetType="DataGrid">
                    
                </Style>
            </DataGrid.Resources>
        </DataGrid>
    </Grid>
</Page>
