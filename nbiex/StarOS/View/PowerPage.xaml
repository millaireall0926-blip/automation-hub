<Page x:Class="StarOS.View.PowerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarOS.View"
      xmlns:vm="clr-namespace:StarOS.ViewModel"
      xmlns:model="clr-namespace:StarOS.Model"
      mc:Ignorable="d" 
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:hc="https://handyorg.github.io/handycontrol"   
      d:DesignHeight="260" d:DesignWidth="800"
      Title="PowerPage">

    <Page.DataContext>
        <vm:PowerVM/>
    </Page.DataContext>

    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="41" Margin="10,0,0,0"  VerticalAlignment="Top" Width="45">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Offset="0"/>
                    <GradientStop Color="#77BBBBBB" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="/Resource/power.png" HorizontalAlignment="Left" Height="32" Margin="16,1,0,0" VerticalAlignment="Top" Width="35"/>
        <TextBlock HorizontalAlignment="Left" Height="47" TextWrapping="Wrap" VerticalAlignment="Top" Width="126" Margin="63,1,0,0" Text="POWER" Foreground="#FFFDFAFA" FontSize="24"/>
        <ToggleButton Content="AutoFit" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="30" Width="60"  HorizontalAlignment="Left" Margin="339,0,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.535,0.65"/>
        <TabControl Margin="0,50,0,0" Width="400" HorizontalAlignment="Left"
                    TabStripPlacement="Left">
            <TabItem Header="Read">
                <Grid Width="390" HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </StackPanel.Resources>
                        <TextBlock Text="DPS1" Width="30"/>
                        <TextBlock Text="S" Width="10"/>
                        <TextBlock Text="RV" Width="40"/>
                        <TextBlock Text="RC" Width="30"/>
                        <TextBlock Text="" Width="5"/>
                        <TextBlock Text="DPS2" Width="28"/>
                        <TextBlock Text="S" Width="20"/>
                        <TextBlock Text="RV" Width="25"/>
                        <TextBlock Text="RC" Width="40"/>
                        <TextBlock Text="" Width="5"/>
                        <TextBlock Text="HV" Width="25"/>
                        <TextBlock Text="S" Width="20"/>
                        <TextBlock Text="RV" Width="30"/>
                        <TextBlock Text="RC" Width="35"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="117"/>
                            <ColumnDefinition Width="117"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0" ItemsSource="{Binding DPS1s}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1" Width="25" Height="16">
                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextAlignment="Center" Foreground="{Binding ColorC}"/>
                                        </Border>
                                        <CheckBox IsChecked="{Binding Show}" Width="20" HorizontalAlignment="Center" Margin="1,0,0,0"/>
                                        <TextBlock Text="{Binding GetV}" Width="35" FontSize="11"/>
                                        <TextBlock Text="{Binding GetC}" Width="35" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DPS2s}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1" Width="25" Height="16">
                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextAlignment="Center" Foreground="{Binding ColorC}"/>
                                        </Border>
                                        <CheckBox IsChecked="{Binding Show}" Width="20" HorizontalAlignment="Center" Margin="1,0,0,0"/>
                                        <TextBlock Text="{Binding GetV}" Width="35" FontSize="11" />
                                        <TextBlock Text="{Binding GetC}" Width="35" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2" ItemsSource="{Binding HVs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1" Width="25" Height="16">
                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextAlignment="Center" Foreground="{Binding ColorC}"/>
                                        </Border>
                                        <CheckBox IsChecked="{Binding Show}" Width="20" HorizontalAlignment="Center" Margin="1,0,0,0"/>
                                        <TextBlock Text="{Binding GetV}" Width="35" FontSize="11"/>
                                        <TextBlock Text="{Binding GetC}" Width="35" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </TabItem>
            
            <TabItem Header="Set" Height="30" VerticalAlignment="Top" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Width" Value="35" />
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </StackPanel.Resources>
                        <TextBlock Text="DPS1" Width="45"/>
                        <TextBlock Text="SV"  Width="35"/>
                        <TextBlock Text="OC"  Width="35"/>
                        <TextBlock Text=""  Width="10"/>
                        <TextBlock Text="DPS2" Width="30"/>
                        <TextBlock Text="SV"  Width="45"/>
                        <TextBlock Text="OC"  Width="30"/>
                        <TextBlock Text=""  Width="10"/>
                        <TextBlock Text="HV" Width="30"/>
                        <TextBlock Text="SV" Width="45"/>
                        <TextBlock Text="OC" Width="30"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="4,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ItemsControl Grid.Column="0" ItemsSource="{Binding DPS1s}" Margin="0,1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"  Margin="0,1">
                                        <StackPanel.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Width" Value="35" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                            </Style>
                                        </StackPanel.Resources>
                                        <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1">
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding ColorC}"/>
                                        </Border>
                                        <TextBlock Margin="5,0,0,0" Text="{Binding SetV}" />
                                        <TextBlock Text="{Binding OC}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DPS2s}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"  Margin="0,1">
                                        <StackPanel.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Width" Value="35" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                            </Style>
                                        </StackPanel.Resources>
                                        <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1">
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding ColorC}"/>
                                        </Border>
                                        <TextBlock Margin="5,0,0,0" Text="{Binding SetV}" />
                                        <TextBlock Text="{Binding OC}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,0" VerticalAlignment="Top">

                                <ItemsControl ItemsSource="{Binding HVs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <StackPanel.Resources>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Width" Value="35" />
                                                        <Setter Property="TextAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </StackPanel.Resources>
                                                <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1">
                                                    <TextBlock Text="{Binding Name}" Foreground="{Binding ColorC}"/>
                                                </Border>
                                                <TextBlock Margin="5,0,0,0" Text="{Binding SetV}" />
                                                <TextBlock Text="{Binding OC}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <StackPanel.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Width" Value="40" />
                                            <Setter Property="TextAlignment" Value="Center" />
                                        </Style>
                                    </StackPanel.Resources>
                                    <TextBlock Text="DAC" Width="40"/>
                                    <TextBlock Text="SV" Width="40"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <ItemsControl ItemsSource="{Binding DACs}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"  Margin="0,1">
                                                    <StackPanel.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Width" Value="35" />
                                                            <Setter Property="TextAlignment" Value="Center" />
                                                        </Style>
                                                    </StackPanel.Resources>
                                                    <Border BorderBrush="{Binding ColorV}" CornerRadius="3" BorderThickness="1">
                                                        <TextBlock Text="{Binding Name}" Foreground="{Binding ColorC}"/>
                                                    </Border>
                                                    <TextBlock Margin="5,0,0,0" Text="{Binding SetV}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
            
        </TabControl>
        
        
        


        <sp:WpfPlot x:Name="xPowerGraph" Margin="400,0,0,0" />




    </Grid>

</Page>
