<UserControl x:Class="LP_MMTCRack.View.Component.RackUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LP_MMTCRack.View.Component"
             xmlns:uc="clr-namespace:LP_MMTCRack.View.Component"
             xmlns:hc="https://handyorg.github.io/handycontrol"  
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="480">
    <Grid Margin="2">
        <Border BorderThickness="2" Style="{StaticResource BorderRegion}" BorderBrush="{Binding BoarderColor}" >
            <Grid Background="{Binding RackColor}" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*" />
                    <RowDefinition Height="6*" />
                    <RowDefinition Height="1.2*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="1,-5,0,0">
                    <!-- Check Box Area -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.8*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="2,0,0,0" FontWeight="DemiBold" FontSize="22" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Run Text="FIX" />
                        <Run Text="{Binding RackViewIndex}"/>
                    </TextBlock>
                    <Button Grid.Column="1" FontSize="11" FontWeight="DemiBold" Padding="1,1" Height="35" Width="65" Command="{Binding RackPopUpClear}" Visibility="Visible">
                        <TextBlock TextAlignment="Center">
                            <Run Text="Fix"/>
                            <Run Text="{Binding RackViewIndex}"/>
                            <LineBreak/>
                            <Run Text="Clear 팝업"/>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="2" FontSize="11" FontWeight="DemiBold" Padding="1,1" Height="35" Width="75" Command="{Binding RackBox1PopUpClear}" Visibility="Visible">
                        <TextBlock TextAlignment="Center">
                            <Run Text="Box"/>
                            <Run Text="{Binding RackBox1ViewIndex}"/>
                            <LineBreak/>
                            <Run Text="Clear 팝업"/>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="3" FontSize="11" FontWeight="DemiBold" Padding="1,1" Height="35" Width="75" Command="{Binding RackBox2PopUpClear}" Visibility="Visible">
                        <TextBlock TextAlignment="Center">
                            <Run Text="Box"/>
                            <Run Text="{Binding RackBox2ViewIndex}"/>
                            <LineBreak/>
                            <Run Text="Clear 팝업"/>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="4" Content="습도&#10;ON" FontSize="12" FontWeight="DemiBold" Padding="1,1" Height="35" Width="35" Command="{Binding RackHumOn}" Visibility="{Binding RackEngrmodeVisibility}"/>
                    <Button Grid.Column="5" Content="습도&#10;OFF" FontSize="12" FontWeight="DemiBold" Padding="1,1" Height="35" Width="35" Command="{Binding RackHumOff}" Visibility="{Binding RackEngrmodeVisibility}"/>
                    <Button Grid.Column="6" Content="모터&#10;AUP" FontWeight="DemiBold" Padding="1,1" Height="35" Width="35" Command="{Binding RackManualUp}" Visibility="{Binding RackEngrmodeVisibility}"/>
                    <Button Grid.Column="7" Content="모터&#10;ADN" FontWeight="DemiBold" Padding="1,1" Height="35" Width="35" Command="{Binding RackManualDown}" Visibility="{Binding RackEngrmodeVisibility}"/>
                </Grid>
                <Grid Grid.Row="1" Margin="3" >
                    <!-- CBox Area-->
                    <ItemsControl ItemsSource="{Binding Boxes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding BoxesCnt}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <uc:BoxUC/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                <Grid Grid.Row ="1" Visibility="{Binding ShowBox}" Margin="0,5,0,3">
                    <Rectangle Fill="{Binding RackMsgColor}"/>
                    <TextBlock Text="{Binding RackMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="굴림" FontWeight="Bold"></TextBlock>
                </Grid>
                <Grid Grid.Row ="1" Visibility="{Binding SlideShowBox}" Margin="0,5,0,3">
                    <Rectangle Fill="{Binding SlideMsgColor}"/>
                    <TextBlock Text="{Binding SlideMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="굴림" FontWeight="Bold"></TextBlock>
                </Grid>

                <Grid Grid.Row="3" Margin="5,0,0,0">
                    <!-- Run/Stop Area-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Run" Height="35" Width="68" Command="{Binding RackCmdRun}"/>
                    <Button Grid.Column="1" Content="Stop" Height="35" Width="68" Command="{Binding RackCmdStop}"/>
                    <TextBox Grid.Column="2" IsReadOnly="True" Height="35" Text="{Binding MotorStatText}" Background="{Binding MotorStatColor}" FontSize="16" FontWeight="DemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" BorderBrush="Black"  Margin="10,0,0,0"/>
                    <Label Grid.Column="3" Background="Transparent" Content="{Binding FlowStatText}" Height="35" Width="90" Foreground="{Binding FlowStatColor}" FontSize="13" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" BorderThickness="0" />
                    <!-- <TextBox Grid.Column="3" IsReadOnly="True" Text="저유량 경고" FontSize="12" FontWeight="DemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="2" BorderBrush="Black" Background="{Binding BoarderColor}" Margin="5,0,5,0"/> -->
                    <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="14">
                        <Run Text="유량 " FontWeight="DemiBold"/>
                        <Run Text="{Binding FlowRate}" Foreground="{Binding FlowRateColor}" FontWeight="DemiBold"/>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
