<UserControl x:Class="LP_MMTCRack.View.Component.ManMotorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:uc="clr-namespace:LP_MMTCRack.View.Component"
             xmlns:local="clr-namespace:LP_MMTCRack.View.Component"
             xmlns:hc="https://handyorg.github.io/handycontrol"  
             mc:Ignorable="d" 
             d:DesignHeight="240" d:DesignWidth="450">
    <Grid Margin="2">
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" BorderBrush="BlanchedAlmond">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="DemiBold" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                   <Run Text="FIX " />
                   <Run Text="{Binding MotorIndex}"/>
                    </TextBlock>
                    <Label Grid.Column="2" Content="STAT" FontSize="14" BorderThickness="0" FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="ALL Clear" Command="{Binding RackCmdStatusClearAll}" Margin="50,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Grid.Column="2" Content="{Binding StatusClear1}" Command="{Binding RackCmdStatusClear1}" Visibility="{Binding ClearBtn1}"  Margin="130,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Grid.Column="2" Content="{Binding StatusClear2}" Command="{Binding RackCmdStatusClear2}" Visibility="{Binding ClearBtn2}" Margin="130,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Grid.Column="2" Content="{Binding StatusClear3}" Command="{Binding RackCmdStatusClear3}" Visibility="{Binding ClearBtn3}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Motor" FontSize="14" BorderThickness="0" FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,5,0,0">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total" Margin="2,0,0,0" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Content="{Binding TotalMotorVal}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="14" Width="60"/>
                            <Button Content="MU" Margin="9,0,0,0" FontSize="14" FontWeight="DemiBold" Command="{Binding CmdManualUp}"/>
                            <Button Content="AU" Margin="7,0,0,0" FontSize="14" FontWeight="DemiBold" Command="{Binding CmdAutoUp}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Value" Margin="2,0,0,0" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox Text="{Binding ManualDownVal}" Margin="5,0,0,0" TextAlignment="Center" FontSize="14" Width="60" />
                            <Button Content="MD" Margin="5,0,0,0" FontSize="14" FontWeight="DemiBold" Command="{Binding CmdManualDown}"/>
                            <Button Content="AD" Margin="5,0,0,0" FontSize="14" FontWeight="DemiBold" Command="{Binding CmdAutoDown}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBox IsReadOnly="True" Height="30" Text="{Binding eMotorStatText}" Background="{Binding eMotorStatColor}" FontSize="16" FontWeight="DemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" BorderBrush="Black"  Margin="0,0,0,0" Width="70"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock Text="Site FW Ver" Margin="2,0,0,0" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Content="{Binding GetSiteVer}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="14" Width="60"/>
                            <Button Content="Get" Margin="9,0,0,0" FontSize="14" FontWeight="DemiBold" Command="{Binding CmdSiteVer}"/>
                        </StackPanel>
                    </StackPanel>
                    

                    <Label Grid.Column="2" Content="TCON" FontSize="14" BorderThickness="0" FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Grid Grid.Column="2" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="135"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Column="1">
                            <ItemsControl ItemsSource="{Binding Tcons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <uc:TconUC/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>

                    <Button Grid.Column="2" Grid.Row="2" Content="RUN" Margin="-70,0,0,0" VerticalAlignment="Bottom" FontSize="14" FontWeight="DemiBold" Command="{Binding RackTconRun}"/>
                    <Button Grid.Column="2" Grid.Row="2" Content="STOP" Margin="70,0,0,0" VerticalAlignment="Bottom" FontSize="14" FontWeight="DemiBold" Command="{Binding RackTConStop}" />

                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
