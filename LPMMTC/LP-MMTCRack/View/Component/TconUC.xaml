<UserControl x:Class="LP_MMTCRack.View.Component.TconUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LP_MMTCRack.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="130" d:DesignWidth="60">
    <Grid>
        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding TconName}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="12" Width="50"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding EngrRackTconstat}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="12" Width="50"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding EngrRackSV}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="12" Width="50"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding EngrRackPV}" Margin="5,0,0,0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="12" Width="50"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
