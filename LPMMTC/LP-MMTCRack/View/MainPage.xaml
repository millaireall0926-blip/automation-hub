<Page x:Class="LP_MMTCRack.View.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LP_MMTCRack.View"
      xmlns:hc="https://handyorg.github.io/handycontrol"  
      xmlns:uc="clr-namespace:LP_MMTCRack.View.Component"
      xmlns:vm="clr-namespace:LP_MMTCRack.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1300"
      Title="MainPage">

    <Page.DataContext>
        <vm:MainPageVM/>
    </Page.DataContext>

    <Grid Margin="10,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="300"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border  Style="{StaticResource BorderRegion}" Margin="2" BorderThickness="2">
                <Grid>
                    <TextBlock Margin="0,0,0,156" Text="All Selection" FontSize="16" FontFamily="Arial" FontWeight="DemiBold" ></TextBlock>
                    <TextBlock Margin="4,34,162,223" Text="All SV" Foreground="DimGray" FontSize="12" FontFamily="Arial" FontWeight="DemiBold"  ></TextBlock>
                    <TextBox Text="{Binding SVAll}" IsEnabled="{Binding EnableSVAll}" Margin="50,27,116,0" RenderTransformOrigin="0.302,0.217" Height="21" VerticalAlignment="Top"></TextBox>
                    <TextBlock Margin="124,37,77,220" Text="℃" Foreground="DimGray" FontSize="12" FontFamily="Arial" FontWeight="DemiBold" RenderTransformOrigin="1.833,0.067"  />
                    <Button Content="SET" Command="{Binding DGCmdAll}" CommandParameter="Set" IsEnabled="{Binding EnableSVAll}" HorizontalAlignment="Right" Margin="0,27,10,0" VerticalAlignment="Top" Width="60" Height="30"/>

                    <Button Content="All Start" Command="{Binding DGCmdAll}" CommandParameter="Start" HorizontalAlignment="Left" Margin="0,65,0,0" VerticalAlignment="Top" Width="110" Height="38"/>
                    <Button Content="All Stop" Command="{Binding DGCmdAll}" CommandParameter="Stop" HorizontalAlignment="Left" Width="110" Margin="115,65,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All Select" Command="{Binding DGCmdAll}" CommandParameter="Select" HorizontalAlignment="Left" Width="110" Margin="0,107,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All None" Command="{Binding DGCmdAll}" CommandParameter="None" HorizontalAlignment="Left" Width="110" Margin="115,107,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="Port ReConnect" Command="{Binding DGCmdAll}" Visibility="{Binding EngrmodeVisibility}" CommandParameter="ReConnect" HorizontalAlignment="Left" Width="110" Margin="0,150,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All Clear 팝업" Command="{Binding DGCmdAll}" CommandParameter="PopUp" HorizontalAlignment="Left" Width="110" Margin="115,150,0,0" VerticalAlignment="Top" Height="38"/>
                    <CheckBox IsChecked="{Binding IsTamsAll}" IsEnabled="{Binding IsTamsAllEnable}" Content="TAMS ALL" Margin="0,2,6,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="84"/>
                    <Button Content="All Motor Down" Command="{Binding DGCmdAll}" Visibility="{Binding EngrmodeVisibility}" CommandParameter="MotorDown" HorizontalAlignment="Left" Width="110" Margin="0,190,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All Motor Up" Command="{Binding DGCmdAll}" Visibility="{Binding EngrmodeVisibility}" CommandParameter="MotorUp" HorizontalAlignment="Left" Width="110" Margin="115,190,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All 습도 Test ON" Padding="0,1" Command="{Binding DGCmdAll}" Visibility="{Binding EngrmodeVisibility}" CommandParameter="HumidityOn" HorizontalAlignment="Left" Width="110" Margin="0,230,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All 습도 Test OFF" Padding="0,1" Command="{Binding DGCmdAll}" Visibility="{Binding EngrmodeVisibility}" CommandParameter="HumidityOff" HorizontalAlignment="Left" Width="110" Margin="115,230,0,0" VerticalAlignment="Top" Height="38"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource BorderRegion}" Margin="2" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Log" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>

                    <Button Content="Clear" Command="{Binding DGCmdAll}" CommandParameter="Clear" Height="28" Margin="0,-2,-6,0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="104"/>

                    <ListView x:Name="xList_Log" Grid.Row="1" Background="White" IsSynchronizedWithCurrentItem="True" Margin="-11" 
                          ItemsSource="{Binding SysLogs}" FontSize="10" >
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}" >
                                <Setter Property="ToolTipService.Placement" Value="RelativePoint" />
                                <Setter Property="ToolTipService.HorizontalOffset" Value="0" />
                                <Setter Property="ToolTipService.VerticalOffset" Value="0" />
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=Message}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="0">
                                        <Setter Property="Foreground" Value="#FF444444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="1">
                                        <Setter Property="Foreground" Value="DarkOrange" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="2">
                                        <Setter Property="Foreground" Value="IndianRed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="105" Header="Time" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Width="500" Header="Message" DisplayMemberBinding="{Binding Message}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Column="1">
            <ItemsControl ItemsSource="{Binding Racks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding LayoutColumnCount}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <uc:RackUC/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

    </Grid>
</Page>
