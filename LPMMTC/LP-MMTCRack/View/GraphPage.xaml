<Page x:Class="LP_MMTCRack.View.GraphPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LP_MMTCRack.View"
      xmlns:vm="clr-namespace:LP_MMTCRack.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1250"
      Title="GraphPage">

    <Page.DataContext>
        <vm:GraphVM/>
    </Page.DataContext>
    
    <Grid Margin="10">
        <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="10">
            <Grid>
                <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="100"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="1">
                                <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="5">
                                    <ItemsControl ItemsSource="{Binding TempDatas}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="{Binding GraphUniformGridCnt}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <Button Content="{Binding Name}" FontSize="15" Width="80" Height="40" Margin="2,0,0,0" Foreground="{Binding ChannelColor}" VerticalAlignment="Center" Command="{Binding DGCButton}" CommandParameter="{Binding boxindex}"/>
                                                    
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,5,0">
                                    <TextBlock Text="{Binding CurName}" FontSize="36" Margin="25,6,0,0" FontWeight="DemiBold" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1" Content="AutoFit" FontSize="18" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="40" Width="90"  HorizontalAlignment="Center"  VerticalAlignment="Center" RenderTransformOrigin="0.535,0.65"/>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,0">
                            <sp:WpfPlot x:Name="xTempGraph"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
