<Page x:Class="LP_MMTCRack.View.EngineerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LP_MMTCRack.View"
      xmlns:vm="clr-namespace:LP_MMTCRack.ViewModel"
      xmlns:uc="clr-namespace:LP_MMTCRack.View.Component"
      xmlns:hc="https://handyorg.github.io/handycontrol"  
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1250"
      Title="EngineerPage">

    <Page.DataContext>
        <vm:EngineerVM/>
    </Page.DataContext>
    
    <Grid Margin="2">
        <Border BorderThickness="2" Style="{StaticResource BorderRegion}" Margin="2">
            <TabControl HorizontalAlignment="Center" Style="{StaticResource TabControlCapsule}" >
                <TabItem Header="Fix Status Parameter">
                    <Border BorderThickness="1" Margin="30,3,30,3" Width="1100" >
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="100"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="600"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="FIX All Status" FontSize="24" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,40,0" />
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock FontWeight="DemiBold" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Run Text="TCon Write Data : "/>
                                        <Run Text="{Binding TconWriteCnt}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" FontWeight="DemiBold" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Run Text="TCon Read Data  : "/>
                                        <Run Text="{Binding TconReadCnt}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Grid.Row="0" FontWeight="DemiBold"  FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Run Text="Site  : "/>
                                        <Run Text="{Binding SiteLoopTime}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Grid.Row="1" FontWeight="DemiBold"  FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Run Text="Capture  : "/>
                                        <Run Text="{Binding CaptureLoopTime}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Grid.Row="2" FontWeight="DemiBold"  FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Run Text="TCon  : "/>
                                        <Run Text="{Binding TConLoopTime}"/>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                           
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ListView Margin="-25,0,0,0" x:Name="xList_Motor" Background="White" IsSynchronizedWithCurrentItem="True" FontSize="9" ItemsSource="{Binding MotorLogs}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListViewItem}" >
                                            <Setter Property="ToolTipService.Placement" Value="RelativePoint" />
                                            <Setter Property="ToolTipService.HorizontalOffset" Value="0" />
                                            <Setter Property="ToolTipService.VerticalOffset" Value="0" />
                                            <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=Message}" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="105" Header="Time" DisplayMemberBinding="{Binding Time}"/>
                                            <GridViewColumn Width="500" Header="Message" DisplayMemberBinding="{Binding Message}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding ManualMotor}" Margin="10,0,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <uc:ManMotorUC/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="TCON Parameter">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Channel List" Margin="5">
                            <ListBox ItemsSource="{Binding ChannelList}" SelectedItem="{Binding SelectedChannel}" Margin="2" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Ellipse Width="10" Height="10" Fill="Green" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StringFormat='Channel {0}'}" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <hc:TabControl Style="{StaticResource TabControlCapsule}" SelectedIndex="{Binding SelectedIndex}" Margin="0,0,0,5">
                                    <hc:TabItem Header="PROCESS"/>
                                    <hc:TabItem Header="FUNCTION"/>
                                    <hc:TabItem Header="SET POINT"/>
                                    <hc:TabItem Header="ALARM"/>
                                    <hc:TabItem Header="PID"/>
                                    <hc:TabItem Header="IN / OUT"/>
                                </hc:TabControl>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentParams}" AutoGenerateColumns="False" CanUserAddRows="False" Style="{StaticResource DataGridBaseStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="300" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="기호" Binding="{Binding Symbol}" Width="120" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="주소" Binding="{Binding Address}" Width="120" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="현재값" Binding="{Binding Value}" Width="120" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="Blue"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="설정값" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanWrite}">
                                                        <TextBox.InputBindings>
                                                            <KeyBinding Key="Enter" 
                                                                        Command="{Binding DataContext.SingleValueWrite, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                        CommandParameter="{Binding}"/>
                                                        </TextBox.InputBindings>
                                                    </TextBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Grid Grid.Row="1" Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ListView x:Name="xList_Para" ItemsSource="{Binding ParaLogs}" FontSize="11" Background="#F5F5F5">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="0,2,0,2"/>
                                            <Setter Property="Padding" Value="5"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Time" Width="130">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Time}" VerticalAlignment="Top" Foreground="Gray"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="Message" Width="850">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Message}" 
                                   TextWrapping="Wrap" 
                                   FontFamily="Consolas" 
                                   LineHeight="18"
                                   Padding="0,2,0,5"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,5,0" Width="150">
                                    <ProgressBar Value="{Binding uiPbint}" Height="15" Margin="0,0,0,10"/>
                                    <Button Content="Read All" Command="{Binding ParaValueRead}" Height="50" Width="100" Style="{StaticResource ButtonPrimary}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>
