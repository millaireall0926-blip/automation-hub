<Window x:Class="StarOS.View.Result"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarOS.View"
        xmlns:vm="clr-namespace:StarOS.ViewModel"
        xmlns:hc="https://handyorg.github.io/handycontrol"         
        mc:Ignorable="d"
        Title="Result" Height="600" Width="1100"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" Background="Green" Loaded="Window_Loaded"
         >

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:ResultVM />
    </Window.DataContext>


    <Grid Background="#DD0D1F0E">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="40*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding SelSlot}" Foreground="#AAAAAAFF" Margin="10,0,0,0" FontSize="16" FontWeight="Bold" FontFamily="Arial Rounded MT Bold" MouseLeftButtonDown="MoveResult"/>
            <Grid Grid.Column="1" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTClose" Background="Transparent" BorderThickness="0" Click="xBTClose_Click">
                    <Image Source="/Resource/close.png" />
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>
            <hc:Card  Grid.Column="0" Background="Black"  Margin="0, 36, 0, 4"  >
                <ListView x:Name="xCard" ItemsSource="{Binding StepModels}" IsSynchronizedWithCurrentItem="True"                            
                                  PreviewMouseLeftButtonUp="ListView_PreviewMouseLeftButtonUp" 
                          Background="#DD223322" FontSize="11" d:ItemsSource="{d:SampleData ItemCount=5}" 
                           >
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="BorderBrush" Value="DarkGray" />
                            <Setter Property="BorderThickness" Value="0,0,0,0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsContact}" Value="true">
                                    <Setter Property="Background" Value="#FF15316D" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsContact}" Value="false">
                                    <Setter Property="Background" Value="#FF175630" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="75" Header="Step"  DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Width="80" Header="Start" DisplayMemberBinding="{Binding Start}"/>
                            <GridViewColumn Width="80" Header="End"   DisplayMemberBinding="{Binding End}"/>
                            <GridViewColumn Width="70" Header="Duration" DisplayMemberBinding="{Binding Duration}"/>
                            <GridViewColumn Width="90" Header="Yeild" DisplayMemberBinding="{Binding Yeild}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </hc:Card>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" >
                <GridSplitter.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#DD12172D"/>
                        <GradientStop Color="#DD325363" Offset="1"/>
                    </LinearGradientBrush>
                </GridSplitter.Background>
            </GridSplitter>

            <Grid Grid.Column="2">
                <Grid.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </Grid.LayoutTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" Source="/Resource/edge.png" Stretch="Uniform"/>
                    <Image Grid.Row="1" Source="/Resource/edge.png" Stretch="Uniform"/>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#FF205020" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RowIndexs}" HeadersVisibility="None" Background="#FF205020" RowHeight="{Binding RowHeight}"                     
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.CanContentScroll="False" IsReadOnly="true" GridLinesVisibility="None" BorderThickness="0"  
                      >
                        <DataGrid.Resources>
                            <Style TargetType="DataGrid">
                                <Setter Property="RowBackground" Value="Transparent"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="9"/>
                                <Setter Property="Foreground" Value="#FFB0C0FF" />
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Margin" Value="4,5,0,0"/>
                                <Setter Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="270"/>
                                    </Setter.Value>
                                </Setter>
                                <!-- Setter Property="Background" Value="red"/ -->
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Line" Binding="{Binding Line}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding ColIndexs}" Background="#FF205010">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <TextBlock
                                Text="{Binding Line}"
                                HorizontalAlignment="Center"                               
                                VerticalAlignment="Bottom"
                                FontSize="10"
                                Foreground="#FFC0B0FF"
                                TextAlignment="Center"
                                FontWeight="DemiBold"  
                                Width="{Binding ColWidth}"
                                Height="16" />

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding DutModels}" x:Name="xBIB" FontSize="10" >
                        <ItemsControl.ItemsPanel >
                            <ItemsPanelTemplate>
                                <Canvas x:Name="xCanvas" SizeChanged="xCanvas_SizeChanged" MouseDown="xCanvas_MouseDown">
                                    <Canvas.Background>
                                        <LinearGradientBrush StartPoint="0 0" EndPoint="1 1">
                                            <LinearGradientBrush.GradientStops>
                                                <GradientStop Offset="0.1" Color="#FF205020" />
                                                <GradientStop Offset="1" Color="#FF90FF90" />
                                            </LinearGradientBrush.GradientStops>
                                        </LinearGradientBrush>
                                    </Canvas.Background>
                                </Canvas>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="{Binding Height}" Height="{Binding Width}"                                 
                                    BorderThickness="2" BorderBrush="#FF303030" Foreground="Black"                          
                                    FontSize="10"
                                    Background="{Binding Color}"                                      
                                    Content="{Binding Text}"
                                    ToolTip="{Binding Text}"             
                                    Uid="{Binding Num}"
                                        
                                    Click="Button_Click"                                
                                    ToolTipService.ShowOnDisabled="False"
                                    VerticalAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold"                                
                                    >
                                    <Button.RenderTransform>
                                        <RotateTransform Angle="270"/>
                                    </Button.RenderTransform>

                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Hide}" Value="true">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Hide}" Value="false">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="Button">
                                        </Style>

                                    </Button.Resources>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>



            <TextBox HorizontalAlignment="Left" Height="26" Margin="2,4,0,0" TextWrapping="Wrap" Text="STEP SELECTION" VerticalAlignment="Top" Width="205" FontSize="16" Background="Transparent" BorderThickness="0" Grid.ColumnSpan="3"/>
            <ToggleButton Content="{Binding TotalText}" IsChecked="{Binding Total}" Height="30" Width="50" FontSize="10" 
                          HorizontalAlignment="Left" Margin="247,4,0,0" VerticalAlignment="Top" Background="#FF1C1C1C" BorderBrush="#FF3F3F46" Foreground="White">
            </ToggleButton>
            <ComboBox HorizontalAlignment="Left" Height="21" Margin="302,4,0,0" VerticalAlignment="Top" Width="100"                      
                      SelectedIndex="{Binding TextMode}" SelectionChanged="ComboBox_SelectionChanged" >
                <ComboBoxItem  Content="-"/>
                <ComboBoxItem  Content="Number"/>
                <ComboBoxItem  Content="IO"/>
                <ComboBoxItem  Content="FailBit"/>
                <ComboBoxItem  Content="ChipID"/>
                <ComboBoxItem  Content="Bin"/>
            </ComboBox>

        </Grid>
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" >
            <GridSplitter.Background>
                <LinearGradientBrush EndPoint="1, 0.5" StartPoint="0, 0.5">
                    <GradientStop Color="#DD12172D"/>
                    <GradientStop Color="#DD349E31" Offset="1"/>
                </LinearGradientBrush>
            </GridSplitter.Background>
        </GridSplitter>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="291*"/>
                    <ColumnDefinition Width="259*"/>
                </Grid.ColumnDefinitions> 
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Grid.ColumnSpan="2">
                    <TextBlock Text="DUT : " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
                    <TextBlock Text="{Binding CurDno}" VerticalAlignment="Center" Width="100" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke"/>
                    <TextBlock Text="TYPE : " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
                    <TextBlock Text="{Binding SubType}" VerticalAlignment="Center" Width="240" HorizontalAlignment="Left" FontSize="18" Foreground="WhiteSmoke"/>
                    <TextBlock Text="COUNT : " VerticalAlignment="Center" FontSize="18" Foreground="WhiteSmoke" Margin="10,0"/>
                    <TextBlock Text="{Binding SubItemCount}" VerticalAlignment="Center" Width="100" FontSize="18" Foreground="WhiteSmoke"/>
                </StackPanel>
                <ListBox x:Name="xListBlock" ItemsSource="{Binding SubBlockModels}" Grid.Row="1" Style="{DynamicResource WrapPanelHorizontalListBox}" Margin="10, 4, 10, 8" Visibility="{Binding ShowBlock}" Grid.ColumnSpan="2">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" BorderBrush="PapayaWhip" Margin="2,2" CornerRadius="2">
                                <TextBlock Padding="2" Text="{Binding Block}" Foreground="MintCream" FontSize="12">
                                    <TextBlock.Resources>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="0">
                                                    <Setter Property="Background" Value="IndianRed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="1">
                                                    <Setter Property="Background" Value="#FFED2F2F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="2">
                                                    <Setter Property="Background" Value="DarkGray"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="3">
                                                    <Setter Property="Background" Value="#FF4C4B4B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Resources>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid Grid.Row="1" Visibility="{Binding ShowDetail}" Grid.ColumnSpan="2" Margin="10, 4, 10, 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*"/>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="20*"/>
                    </Grid.ColumnDefinitions>
                    <ListView x:Name="xListView_Block" Grid.Column="0" Margin="10, 10, 0, 10" ItemsSource="{Binding SubFDetailBlocks}" Style="{StaticResource ListView.Small}" Visibility="{Binding ShowDetail}" Foreground="White" Background="#FF242469"
                           PreviewMouseLeftButtonUp="ListViewDetail_PreviewMouseLeftButtonUp">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding Text}" Header="BLOCK" Width="300"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <ListView x:Name="xListView_Page" Grid.Column="1" FontSize="10" Margin="10, 10, 0, 10" ItemsSource="{Binding SubFDetailPages}" Visibility="{Binding ShowDetail}" Style="{StaticResource ListView.Small}" Foreground="White" Background="#FF154356"
                          PreviewMouseLeftButtonUp="ListViewDetail_PreviewMouseLeftButtonUp">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding Text}" Header="PAGE" Width="300" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <ListBox Grid.Column="2" Margin="10" ItemsSource="{Binding SubFDetailCols}" Visibility="{Binding ShowDetail}" Foreground="AntiqueWhite" Background="#FF248069">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" FontSize="10" Foreground="White"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                <TextBox Grid.Row="1" Visibility="{Binding ShowBin}"  Margin="10, 4, 10, 8" Text="{Binding BinText}"                     
                     AcceptsReturn="True" FontFamily="Courier New" FontSize="10" IsReadOnly="True"
                     VerticalScrollBarVisibility="Visible" Grid.ColumnSpan="2"/>
                <DataGrid Grid.Row="1" Visibility="{Binding ShowCycle}"  Margin="10, 4, 10, 8" ItemsSource="{Binding DT_Cycle}" Grid.ColumnSpan="2">
                    <DataGrid.Resources>
                        <Style TargetType="DataGrid">
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" >
                <GridSplitter.Background>
                    <LinearGradientBrush EndPoint="1, 0.5" StartPoint="0, 0.5">
                        <GradientStop Color="#FF12172D"/>
                        <GradientStop Color="#FF349E31" Offset="1"/>
                    </LinearGradientBrush>
                </GridSplitter.Background>
            </GridSplitter>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="5,0,0,0" Text="BIN TOTAL" Foreground="WhiteSmoke" FontSize="18"></TextBlock>
                <hc:Card Grid.Row="1" Margin="8,0,8,8">
                    <ScrollViewer  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="xSP_Bin"/>
                    </ScrollViewer>
                </hc:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>
