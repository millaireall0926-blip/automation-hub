<Window x:Class="StarOS.View.PgmCheckView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PGM Check" Height="500" Width="680" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.4"/>
        </Border.Effect>

        <Border Background="#1E1E1E" BorderBrush="#FF5252" BorderThickness="2" CornerRadius="12" ClipToBounds="True">
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="⚠️" FontSize="30" Foreground="#FF5252" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="PGM CONSISTENCY WARNING" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#2D2D30" BorderBrush="#1890FF" BorderThickness="2" Padding="20,15" CornerRadius="8" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="[ MASTER REFERENCE ]" FontWeight="Bold" Foreground="#85929E" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding MasterSlot.Name}" FontSize="22" FontWeight="ExtraBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" Text="|" FontSize="22" Foreground="#566573" Margin="15,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding MasterSlot.PgmName}" FontSize="22" FontWeight="ExtraBold" Foreground="#4DA8DA" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Mismatching Slots List :" FontSize="14" Foreground="#85929E" Margin="5,0,0,8" FontWeight="Bold"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ConflictSlots}" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="#252526" BorderBrush="#3E3E42" RowHeaderWidth="0" SelectionMode="Single"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Slot ID" Binding="{Binding Name}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="15"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Target PGM Name (Mismatch)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PgmName}" Foreground="#FF5252" FontWeight="Bold" FontSize="15"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" Padding="10,5,5,5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Ignore &amp; Test" Click="BtnOk_Click" Width="170" Height="45" Margin="0,0,12,0" 
                            Background="#FF5252" Foreground="White" FontWeight="Bold" FontSize="15" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Cancel" Click="BtnCancel_Click" Width="110" Height="45" 
                            Background="#566573" Foreground="White" FontWeight="Bold" FontSize="15" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>