<Window x:Class="StarLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarLauncher"
        xmlns:vm="clr-namespace:StarLauncher.ViewModel"
        mc:Ignorable="d"     
        
        AllowsTransparency="True" WindowStyle="None" Background="Transparent"

        
        Title="StarLauncher" Height="140" Width="560" >

    
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>

    <Window.Resources>


        <Style x:Key="xsTitleButton" TargetType="{x:Type Grid}">
            <Setter Property="Background" Value="Transparent" ></Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True" >
                    <Setter Property="Background" Value="#AAAAAAAA"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="False" >
                    <Setter Property="Background" Value="#00000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Viewbox>
                            <Border x:Name="Border" CornerRadius="10" Background="#503050ff" Width="40" Height="20">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0.5" Direction="0" Opacity="0.3" />
                                </Border.Effect>
                                <Ellipse x:Name="Ellipse" Fill="#aa7080FF" Stretch="Uniform" Margin="2 1 2 1" Stroke="Gray" StrokeThickness="0.2" HorizontalAlignment="Stretch">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.3" Direction="260" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Viewbox>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#A01020FF" Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse" Storyboard.TargetProperty="Margin" To="20 1 2 1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#503050ff" Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse" Storyboard.TargetProperty="Margin" To="2 1 2 1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0 0" EndPoint="1 1">
                <LinearGradientBrush.GradientStops>
                    <GradientStop Offset="0.1" Color="#AA606090" />
                    <GradientStop Offset="1" Color="#AA151d29" />
                </LinearGradientBrush.GradientStops>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>

            <!--explane 
            M : Move
            L : Line
            H : Horizontal Line
            V : Vertical Line
            C : Cubic Bezier Curve
            Q : Quadratic Bezier Curve
            S : Smooth cubic Bezier curve
            A : Elliptical Arc
            Z : Close
            P : Point 
            -->
            <TextBlock Grid.Column="0" Text="STAR  PROGRAMS - HSBI" Foreground="#DDbbbbbb" Margin="10,0,0,0" FontSize="14" FontWeight="Bold" MouseLeftButtonDown="MoveTitle"/>
            <Grid Grid.Column="1" HorizontalAlignment="Center" Style="{StaticResource xsTitleButton}" >
                <Button x:Name="xBTMin" Background="Transparent" BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resources/min.png" />
                </Button>
            </Grid>

            <Grid Grid.Column="2" HorizontalAlignment="Center">
                <Button x:Name="xBTClose" Background="Transparent"  BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resources/close.png" />
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="Alive OS" Foreground="DodgerBlue" TextAlignment="Center" FontSize="12" Margin="0,30,0,0"/>
                <ToggleButton Width="50" Height="30" Margin="0,10,0,0" IsChecked="{Binding AliveOS}"></ToggleButton>
            </StackPanel>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding ToolModels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button 
                                Command="{Binding Command}"
                                ToolTip="{Binding Tip}"
                                Height="100" Width="120"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" BorderThickness="0" Visibility="{Binding IsVisible}"
                                Background="Transparent">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="30" />
                                </Style>
                            </Button.Resources>
                            <Button.Content>
                                <Grid Background="Transparent">
    
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                                    Background="#A0C0FF"
                                                    Width="52" Height="48"
                                                    VerticalAlignment="Bottom"                                                
                                                    CornerRadius="20">
                                        <Image Source="{Binding Icon}"
                                                       Margin="10,0,10,0"
                                                       Width="32" Height="32" />
                                    </Border>
                                    <Border Grid.Row="1" 
                                                    HorizontalAlignment="Stretch" 
                                                    VerticalAlignment="Stretch"
                                                    Background="#404080"
                                                    Margin="0,4,0,0" 
                                                    Width="80" Height="32"
                                                    CornerRadius="10">
    
                                        <TextBlock Text="{Binding Title}"
                                                           FontSize="13px"                                                       
                                                           FontFamily="Fixed Sys"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Foreground="WhiteSmoke" />
    
                                    </Border>
                                </Grid>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
    
            </ItemsControl>
        </Grid>



        <Grid  Grid.Row="2" >
            <Grid.Background>
                <LinearGradientBrush StartPoint="0 0" EndPoint="1 1">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Offset="0.1" Color="#FF8080CC" />
                        <GradientStop Offset="1" Color="#FF303030" />
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Grid.Background>
            <Image Source="/Resources/logo.bmp" Margin="0,0,4,0" HorizontalAlignment="Right"/>
        </Grid>

    </Grid>


</Window>
