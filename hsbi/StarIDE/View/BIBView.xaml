<Window x:Class="StarIDE.View.BIBView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarIDE.View"
        xmlns:hc="https://handyorg.github.io/handycontrol"                      
        xmlns:vm="clr-namespace:StarIDE.ViewModel"          
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        mc:Ignorable="d"
        WindowStyle="None" ResizeMode="CanResize" Background="Transparent" 
        Title="BIBView" Height="800" Width="900">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
    
        <Grid Grid.Row="0" Background="#DD395C96">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Burn In Board Setting" Foreground="WhiteSmoke" Margin="10,0,0,0" FontSize="16" FontWeight="Bold" FontFamily="Calibri" MouseLeftButtonDown="MoveTitle"/>
            <Grid Grid.Column="1" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTMin" Background="Transparent" BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/min.png" />
                </Button>
            </Grid>
            <Grid Grid.Column="2" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTRestore" Background="Transparent"  BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/restore.png" />
                </Button>
            </Grid>
            <Grid Grid.Column="3" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTClose" Background="Transparent" BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/close.png" />
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="3" />
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" >
                <TextBlock Text="LAYOUT" FontSize="24" Foreground="White" VerticalAlignment="Center" Margin="5,0,20,0"/>
                <TextBlock Text="COL" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                <hc:NumericUpDown Value="{Binding Column}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <TextBlock Text="ROW" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                <hc:NumericUpDown Value="{Binding Row}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <TextBlock Text="IO" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                <hc:NumericUpDown Value="{Binding IOCount}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <TextBlock Text="MC" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                <hc:NumericUpDown Value="{Binding MultiChip}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <Button Uid="SET" DockPanel.Dock="Right" Width="130" Height="42"  Command="{Binding CmdBIB}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resource/biblayout.png" Stretch="Fill"/>
                        <TextBlock Text="Set Layout" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </DockPanel>

            <DataGrid Grid.Row="1" x:Name="xDG_BIB"                       
                      GridLinesVisibility="All"                     
                      VerticalGridLinesBrush="#FF2D2D30"                             
                      ColumnHeaderHeight="30"                      
                      SelectionMode="Extended"
                      ColumnWidth="82"
                      SelectionUnit="Cell"
                      RowHeaderWidth="38"   
                      RowHeight="34"
                      HeadersVisibility="All"
                      LoadingRow="xDG_BIB_LoadingRow"
                      IsSynchronizedWithCurrentItem="True"
                      SelectedCellsChanged="xDG_BIB_SelectedCellsChanged"
                      >
                        <!--AlternatingRowBackground="Gray"-->
                <DataGrid.Resources >
                    <!--Style TargetType="DataGrid">
                    </Style-->
                </DataGrid.Resources>

            </DataGrid>
            
            <!--WindowsFormsHost Grid.Row="1">
                <wf:DataGridView x:Name="xDGV_BIB" MultiSelect="True"  />
            </WindowsFormsHost-->

            <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch"/>
            <DockPanel Grid.Row="3" LastChildFill="true">
                <DockPanel DockPanel.Dock="Top"  Height="50">
                    <TextBlock Text="MAKE" FontSize="24" Foreground="White" VerticalAlignment="Center" Margin="5,0,20,0"/>
                    <TextBlock Text="SCAN Inc" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                    <hc:NumericUpDown Value="{Binding ScanInc}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Text="IO Inc" FontSize="18" Foreground="WhiteSmoke" Margin="10" VerticalAlignment="Center"/>
                    <hc:NumericUpDown Value="{Binding IOInc}" Width="70" FontSize="16" Margin="3" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>

                    <Button Uid="UP" Command="{Binding CmdBIB}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Height="38" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resource/uparrow.png" />
                            <TextBlock Margin="4,0,0,0" Text="Copy Right"  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Uid="RIGHT" Command="{Binding CmdBIB}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Height="38" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resource/arrowright.png" />
                            <TextBlock Margin="4,0,0,0" Text="Copy Right"  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Uid="MAKE" DockPanel.Dock="Right" Width="130" Height="42" Command="{Binding CmdBIB}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" >
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resource/bibbuild.png" Stretch="Fill"/>
                            <TextBlock Text="To Source" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
                
                
                    <TextBox DockPanel.Dock="Bottom"                               
                             HorizontalContentAlignment="Left"
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Visible"
                             FontSize="11"
                             FontWeight="Bold"
                             Text="{Binding BIBText}"
                             />


                
            </DockPanel>
        </Grid>

    </Grid>
</Window>
