<UserControl x:Class="StarIDE.View.FindView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:StarIDE.View"
             xmlns:sc="clr-namespace:ScintillaNET;assembly=ScintillaNET"
             mc:Ignorable="d" 
             d:DesignHeight="62" d:DesignWidth="600" Focusable="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="82"/>
            <ColumnDefinition Width="34"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical">
            <Grid Margin="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Find"/>
                <TextBox x:Name="xTB_Find" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                         Text="{Binding FindText,  UpdateSourceTrigger=PropertyChanged}"  FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                         KeyDown="xTB_Find_KeyDown"/>
            </Grid>
            <Grid Margin="1" Visibility="{Binding ReplaceVisible}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"  TextWrapping="Wrap" Text="Replace"/>
                <TextBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextWrapping="Wrap" 
                         Text="{Binding ReplaceText ,  UpdateSourceTrigger=PropertyChanged}" 
                         KeyDown="xTB_Find_KeyDown"/>
            </Grid>
        </StackPanel>
        <Grid Grid.Column="1">
            <ComboBox HorizontalAlignment="Center" Height="28" Margin="0,31,0,0" VerticalAlignment="Top" Width="Auto" SelectedIndex="{Binding FindAll}">
                <ComboBoxItem Content="Current" />
                <ComboBoxItem Content="All Files" />
            </ComboBox>
            <ToggleButton Margin="4,0,0,0" IsChecked="{Binding IsUpperLower}" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource ToggleButtonInfo}" ToolTip="case sensitive">
                <Image Source="/Resource/upperlowercase.png"/>
            </ToggleButton>
            <ToggleButton Margin="48,0,0,0" IsChecked="{Binding IsWrap}" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource ToggleButtonWarning}" ToolTip="Wrap">
                <Image Source="/Resource/wrap-text.png"/>
            </ToggleButton>


        </Grid>

        <StackPanel Grid.Column="2" Orientation="Vertical">
            <Button Margin="1" FontSize="10" Content="Find Prev" Visibility="{Binding FindVisible}" ToolTip="F2 or (Shift + Enter)"
                    Command="{Binding cmdFind}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <Button Margin="1" FontSize="10" Content="Find Next" Visibility="{Binding FindVisible}" ToolTip="F3 or Enter"
                    Command="{Binding cmdFind}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <Button Margin="1" FontSize="10" Content="Replace Prev" Visibility="{Binding ReplaceVisible}" ToolTip="Shift + Enter"
                    Command="{Binding cmdFind}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <Button Margin="1" FontSize="10" Content="Replace Next" Visibility="{Binding ReplaceVisible}" ToolTip="Enber"
                    Command="{Binding cmdFind}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
        </StackPanel>
        
        <Grid Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="top"  Style="{StaticResource xsTitleGrid}">
            <Button Background="Transparent" BorderThickness="0" Click="Button_Click">
                <Image Source="/Resource/close.png" />
            </Button>
        </Grid>


    </Grid>
</UserControl>
