<Page x:Class="StarIDE.View.FilesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarIDE.View"
      xmlns:hc="https://handyorg.github.io/handycontrol"              
      xmlns:vm="clr-namespace:StarIDE.ViewModel"   
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FilesView">

    <Page.DataContext>
        <vm:FilesVM />
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="2*"  />
            <RowDefinition Height="24" />
            <RowDefinition Height="*"  />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF34425A" />
        <TextBlock Grid.Row="0" FontSize="24" Text="{Binding FolderName}" Foreground="WhiteSmoke" HorizontalAlignment="Left"/>
        
        <TreeView  Grid.Row="1" x:Name="xTV_Files" ItemsSource="{Binding FileModels}" Background="#FF3F5478" BorderThickness="0"
                                         SelectedItemChanged="xTV_Files_SelectedItemChanged" >
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding InnerFiles}">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New" Click="menuCommand" />
                                <MenuItem Header="New Folder" Click="menuCommand"/>
                                <Separator Background="Green"/>
                                <MenuItem Header="Copy" Click="menuCommand"/>
                                <MenuItem Header="Delete" Click="menuCommand"/>
                                <MenuItem Header="Rename" Click="menuCommand"/>
                                <Separator Background="Blue"/>
                                <MenuItem Header="Open Explorer" Click="menuCommand"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBox Text="{Binding Type}" IsReadOnly="true" FontSize="11" FontWeight="Bold"
                                                          VerticalAlignment="Center" Height="20" TextAlignment="Center" VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Style.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="3" />
                                        </Style>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="0">
                                            <!-- CPP -->
                                            <Setter Property="Foreground" Value="DarkGreen"/>
                                            <Setter Property="Background" Value="LightGreen"/>
                                            <Setter Property="BorderThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="1">
                                            <!-- PAT -->
                                            <Setter Property="Foreground" Value="DarkBlue"/>
                                            <Setter Property="Background" Value="LightSkyBlue"/>
                                            <Setter Property="BorderThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="2">
                                            <!-- HEAD -->
                                            <Setter Property="Foreground" Value="DarkViolet"/>
                                            <Setter Property="Background" Value="PaleVioletRed"/>
                                            <Setter Property="BorderThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="3">
                                            <!-- VEC -->
                                            <Setter Property="Foreground" Value="DarkRed"/>
                                            <Setter Property="Background" Value="IndianRed"/>
                                            <Setter Property="BorderThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="4">
                                            <!-- ETC -->
                                            <Setter Property="Foreground" Value="DarkKhaki"/>
                                            <Setter Property="Background" Value="LightYellow"/>
                                            <Setter Property="BorderThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="5">
                                            <!-- FOLDER -->
                                            <Setter Property="Foreground" Value="DarkSlateGray"/>
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="BorderBrush" Value="Gray"/>
                                            <Setter Property="BorderThickness" Value="3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="{Binding Name}"  VerticalAlignment="Center" Margin="8,0,0,0" Visibility="{Binding IsTextBlock}" 
                                                         FontSize="11" Foreground="{Binding Color}" Background="Transparent" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged }"  VerticalAlignment="Center" Margin="8,0,0,0" Visibility="{Binding IsTextBox}" BorderThickness="2"
                                                         FontSize="11" Foreground="{Binding Color}" FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}" >
                            <TextBox.InputBindings>
                                <KeyBinding Command="{Binding ReNameCommand}" Key="Enter"/>
                                <KeyBinding Command="{Binding ReNameCommand}" Key="Esc"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>

        </TreeView>

        <hc:LoadingCircle Grid.Row="1" Visibility="{Binding CompVisible}" />


        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch"  Background="#FF34425A" />
        <TextBlock Grid.Row="2" FontSize="16" Text="COMPILED" Foreground="WhiteSmoke" HorizontalAlignment="Left" Background="#FF334158"/>
        
        <TreeView  Grid.Row="3" x:Name="xTV_Maked" ItemsSource="{Binding MakedModels}" Background="#FF283140" BorderThickness="0">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Uid="BuildItem" Header="Delete" Click="menuCommand"/>
                                <MenuItem Uid="BuildItem" Header="Delete All" Click="menuCommand"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBox Text="{Binding Type}" IsReadOnly="true" FontSize="11" FontWeight="Bold"
                                 BorderBrush="{Binding Color}" BorderThickness="3" VerticalAlignment="Center" Height="24" TextAlignment="Center" VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Style.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="3" />
                                        </Style>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="0">
                                            <!-- PGM -->
                                            <Setter Property="Foreground" Value="#FF76CE5E"/>
                                            <Setter Property="Background" Value="#FF1B380D"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="1">
                                            <!-- MPA -->
                                            <Setter Property="Foreground" Value="#FF7777D4"/>
                                            <Setter Property="Background" Value="#FF102C3E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="{Binding Name}"  VerticalAlignment="Center" Margin="8,0,0,0"
                                                         FontSize="11"  Background="Transparent" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>


        <Border Grid.Row="3" VerticalAlignment="Center" Width="60" Background="#BB2B4EDA" CornerRadius="10" Visibility="{Binding CompVisible}">
            <hc:LoadingCircle Style="{StaticResource LoadingCircleLight}" Margin="10" Visibility="{Binding CompVisible}"/>
        </Border>

    </Grid>
</Page>
