<Window x:Class="StarRouter.View.Edit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarRouter.View"
        AllowsTransparency="True" WindowStyle="None" Background="{x:Null}" 
        mc:Ignorable="d" 
        xmlns:hc="https://handyorg.github.io/handycontrol" 
        Title="Edit" Height="230" Width="500" KeyDown="Window_KeyDown"
        >
    <Grid Margin="0,0,45,0">

        <Image Height="269"  VerticalAlignment="Top" Source="/Resource/ipaddr.png" MouseDown="Image_MouseDown"/>
        <Rectangle Margin="1,136,0,0" Fill="#007bf7" Height="93" VerticalAlignment="Top"/>
        <hc:TextBox hc:InfoElement.Placeholder="Name"  Text="{Binding EditName}" Margin="10,144,345,0" Height="31" VerticalAlignment="Top"/>
        <hc:TextBox hc:InfoElement.Placeholder="IP"  Text="{Binding EditIP}" Margin="125,144,128,0" Height="31" VerticalAlignment="Top"/>
        <hc:TextBox hc:InfoElement.Placeholder="Port"  Text="{Binding EditPort}" Margin="340,144,10,55"/>

        <Button Content="Cancle" Click="Button_Click" HorizontalAlignment="Left" Margin="232,188,0,0" VerticalAlignment="Top" 
            Width="95" Height="32" Background="#6e3b90"/>
        <Button Content="OK" Click="Button_Click" HorizontalAlignment="Left" Margin="340,188,0,0" VerticalAlignment="Top" 
                Width="95" Height="32" Background="#3e4b90"/>
        
    </Grid>

</Window>
