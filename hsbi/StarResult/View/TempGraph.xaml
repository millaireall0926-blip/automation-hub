<Page x:Class="StarResult.View.TempGraph"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StarResult.View"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:vm="clr-namespace:StarResult.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TempGraph">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel ToggleButton.Checked="Graph_Mode_Select" Orientation="Horizontal" VerticalAlignment="Stretch" Background="SaddleBrown" >
            <TextBox Text="Wave  " Background="SaddleBrown" Foreground="WhiteSmoke" FontWeight="Bold" BorderThickness="0"/>
            <RadioButton Name="xRB_All" IsChecked="{Binding IsTempAllStep}" Content="All" Margin="4" Foreground="WhiteSmoke"></RadioButton>
            <RadioButton Name="xRB_Step" Content="Step" Margin="4" Foreground="WhiteSmoke"></RadioButton>
        </StackPanel>
        <sp:WpfPlot Grid.Row="1" x:Name="xTempGraph" />
    </Grid>
</Page>
