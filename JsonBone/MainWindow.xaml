<Window x:Class="JsonBone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JsonBone"
        Title="Spine JSON Bone Analyzer Ver 1.0.5 - Add GIF " Height="700" Width="1500"
        Background="#1E1E1E">

    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <TextBlock Text="1. JSON 파일 선택" DockPanel.Dock="Top" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#E0E0E0"/>
            <Button DockPanel.Dock="Top" Content="📁 폴더 열기" Command="{Binding SelectFolderCommand}" Height="35" Margin="0,0,0,10" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <GroupBox Header="파일 목록" Foreground="#AAAAAA" BorderBrush="#3F3F46">
                <ListBox x:Name="FileListBox" ItemsSource="{Binding FileList}" DisplayMemberPath="Name" SelectionMode="Extended" Background="#252526" Foreground="#DCDCDC" BorderThickness="0"/>
            </GroupBox>
        </DockPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <Button Content="변환 ▶" Command="{Binding ConvertCommand}" CommandParameter="{Binding SelectedItems, ElementName=FileListBox}" Width="80" Height="100" Background="#005A9E" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="병합 복사" Command="{Binding CopyCommand}" Width="80" Height="50" Background="#217346" Foreground="White" FontWeight="Bold" Margin="0,50,0,0" BorderThickness="0"/>
        </StackPanel>

        <DockPanel Grid.Column="2" Margin="10,0,0,0">
            <TextBlock Text="2. 분석 결과 (헤더 이름 수정 가능)" DockPanel.Dock="Top" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#E0E0E0"/>
            <DataGrid x:Name="MainDataGrid" ItemsSource="{Binding SpineDataList}" 
          AutoGenerateColumns="False"
          Background="#1E1E1E" RowBackground="#252526" AlternatingRowBackground="#2D2D30"
          Foreground="#DCDCDC" HorizontalGridLinesBrush="#3F3F46" VerticalGridLinesBrush="#3F3F46"
          FontSize="14" 
          RowHeight="40"  VerticalContentAlignment="Center" SelectionUnit="FullRow"
          ClipboardCopyMode="IncludeHeader" BorderBrush="#3F3F46"
          CanUserSortColumns="False"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#333337"/>
                        <Setter Property="Foreground" Value="#F1F1F1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="0,5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Resources>
                    <Style x:Key="HeaderTextBox" TargetType="TextBox">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="CaretBrush" Value="White"/>
                    </Style>

                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="10,0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="50" IsReadOnly="True">
                        <DataGridTemplateColumn.Header>
                            <TextBox Text="GIF" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#3F3F46" Margin="0" Padding="3">
                                    <Image Source="{Binding ImagePath, IsAsync=True}" 
                       Stretch="Uniform" 
                       RenderOptions.BitmapScalingMode="LowQuality">
                                        <Image.ToolTip>
                                            <ToolTip Background="#2D2D30" BorderBrush="#3F3F46" HasDropShadow="True">
                                                <Image Source="{Binding ImagePath, IsAsync=True}" Width="250" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </ToolTip>
                                        </Image.ToolTip>
                                    </Image>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Binding="{Binding No}" Width="45" IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBox Text="No" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding FileName}" Width="230" IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBox Text="Json" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#9CDCFE"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding AnimationName}" Width="150" IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBox Text="Animation" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Duration}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBox Text="Duration" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridCheckBoxColumn Binding="{Binding IsLoop, UpdateSourceTrigger=PropertyChanged}" Width="60">
                        <DataGridCheckBoxColumn.Header>
                            <TextBox Text="Loop" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridCheckBoxColumn.Header>
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Binding="{Binding Slot}" Width="180">
                        <DataGridTextColumn.Header>
                            <TextBox Text="Slot" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Skin}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBox Text="Skin" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Description}" Width="*">
                        <DataGridTextColumn.Header>
                            <TextBox Text="설명" Style="{StaticResource HeaderTextBox}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>