<Window x:Class="TempView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TempView.ViewModel"        
        xmlns:hc="https://handyorg.github.io/handycontrol"         
        xmlns:local="clr-namespace:TempView"
        mc:Ignorable="d"
        AllowsTransparency="True" WindowStyle="None" ResizeMode="CanResizeWithGrip" Background="Transparent" 
        Title="MainWindow" Height="880" Width="1200" Closed="Window_Closed">

    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>
    
    <Grid Background="#CCdee3ef">
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="xTB_Title"  Grid.Column="0" Foreground="#AA170501" Margin="10,0,0,0" FontSize="16" FontWeight="Bold" FontFamily="Calibri" MouseLeftButtonDown="MoveTitle"/>
            <Grid Grid.Column="1" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTMin" Background="Transparent" BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/min.png" />
                </Button>
            </Grid>
            <Grid Grid.Column="2" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTRestore" Background="Transparent"  BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/restore.png" />
                </Button>
            </Grid>
            <Grid Grid.Column="3" HorizontalAlignment="Center"  Style="{StaticResource xsTitleGrid}">
                <Button x:Name="xBTClose" Background="Transparent" BorderThickness="0" Click="ClickTileButton">
                    <Image Source="/Resource/close.png" />
                </Button>
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24" />
                </Grid.RowDefinitions>
                <hc:Card x:Name="xCard" Grid.Column="0" Background="#FFFFFF" Margin="5,0,5,10" Grid.ColumnSpan="2" >
                    <Frame Source="/View/SelectView.xaml" />
                </hc:Card>
                <StackPanel Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                    <Button Background="Transparent" Command="{Binding PathCmd}" Width="46" Height="36" BorderThickness="0" >
                        <Image Source="/Resource/path.png" />
                    </Button>
                    <TextBlock Background="Transparent" Text="{Binding DataPath}" Margin="5" 
                            VerticalAlignment="Center" Foreground="Black" 
                            FontSize="14" FontWeight="Bold" FontFamily="FixedSys"/>
                </StackPanel>

            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="SlateGray" Margin="0,0,4,8"/>

            <Grid Grid.Column="2">
                <hc:Card Margin="0,0,10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="500"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock FontSize="24" Text="Temp Graph  " VerticalAlignment="Center" FontFamily="bold"/>
                                <TextBlock FontSize="20" Text="{Binding Selected}" VerticalAlignment="Center" Foreground="DimGray" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" >
                                <TextBlock Text="GuideLine" VerticalAlignment="Center"  FontSize="16" FontWeight="DemiBold" Margin="0,0,5,0"/>
                                <Button Content="clear" Command="{Binding LineCmd}" CommandParameter="clear" Margin="0,0,10,0"></Button>
                                <TextBlock Text="Time" VerticalAlignment="Center" Foreground="Green" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding TimeLineInput}" Width="50" Height="30" FontSize="11"/>
                                <Button Content="+" Command="{Binding LineCmd}" CommandParameter="addTime" Width="30"></Button>
                                <Button Content="-" Margin="0,0,20,0" Command="{Binding LineCmd}" CommandParameter="delTime" Width="30"></Button>

                                <TextBlock Text="Temp" VerticalAlignment="Center" Foreground="Red" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding TempLineInput}" Width="50" Height="30" FontSize="11"/>
                                <Button Content="+" Command="{Binding LineCmd}" CommandParameter="addTemp"></Button>
                                <Button Content="-" Margin="0,0,10,0" Command="{Binding LineCmd}" CommandParameter="delTemp" Width="30"></Button>
                            </StackPanel>
                            
                            
                        </Grid>
                        <Frame Grid.Row="1" Source="/View/GraphView.xaml" />
                    </Grid>
                </hc:Card>
            </Grid>
        </Grid>
        
    </Grid>
</Window>
