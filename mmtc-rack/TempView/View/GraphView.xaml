<Page x:Class="TempView.ViewModel.GraphView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TempView.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:vm="clr-namespace:TempView.ViewModel"        
      xmlns:hc="https://handyorg.github.io/handycontrol"      
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:model="clr-namespace:TempView.Model"
      Title="GraphView">

    <Page.DataContext>
        <vm:GraphVM />
    </Page.DataContext>
    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Center">
                <ToggleButton x:Name="xBoxA" Content="A" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonPrimary}" IsChecked="True" Click="xBoxA_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
                <ToggleButton x:Name="xBoxB" Content="B" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSuccess}" IsChecked="True" Click="xBoxA_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Center">
                <ToggleButton x:Name="xBoxC" Content="C" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonWarning}" IsChecked="True" Click="xBoxA_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,5,0">
                <TextBlock Text="ALL " Foreground="Black" VerticalAlignment="Center"></TextBlock>
                <ToggleButton Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSwitch}" IsChecked="True"  Click="ToggleDimmAll_Click" />
            </StackPanel>
            <ItemsControl Grid.Row="1" ItemsSource="{Binding DimDatas}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                            <TextBlock Text="{Binding Name}" Foreground="{Binding ChanelColor}" VerticalAlignment="Center"></TextBlock>
                            <ToggleButton Uid="{Binding Name}" Margin="2,0,0,0" IsChecked="{Binding Show}" 
                                                          Style="{StaticResource ToggleButtonSwitch}" Command="{Binding DGToggle}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        
        <sp:WpfPlot Grid.Column="2" x:Name="xDimGraph" MouseMove="xDimGraph_MouseMove"></sp:WpfPlot>

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,5,0">
                <TextBlock Text="ALL " Foreground="Black" VerticalAlignment="Center"></TextBlock>
                <ToggleButton Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSwitch}" IsChecked="True"  Click="ToggleEtcAll_Click" />
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding EtcDatas}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                            <TextBlock Text="{Binding Name}" Foreground="{Binding ChanelColor}" VerticalAlignment="Center"></TextBlock>
                            <ToggleButton Uid="{Binding Name}" Margin="2,0,0,0" IsChecked="{Binding Show}" 
                                                          Style="{StaticResource ToggleButtonSwitch}" Command="{Binding DGToggle}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
         </Grid>
    </Grid>
</Page> 
