<UserControl x:Class="HTCRack.View.Component.RegisterUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack.View.Component"
             x:Name="ucReg"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <UserControl.Resources>

        <Storyboard x:Key="storySend">
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="xWRITE" Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)">
                <EasingColorKeyFrame KeyTime="00:00:00" Value="White"/>
                <EasingColorKeyFrame KeyTime="00:00:00.4000000" Value="#FF2CBEDA"/>
                <EasingColorKeyFrame KeyTime="00:00:00.8000000" Value="White"/>
            </ColorAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="xSEND" Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)">
                <EasingColorKeyFrame KeyTime="00:00:00" Value="#FF45ABAD"/>
                <EasingColorKeyFrame KeyTime="00:00:00.4000000" Value="White"/>
                <EasingColorKeyFrame KeyTime="00:00:00.8000000" Value="#FF45ABAD"/>
            </ColorAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="xWV" Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)">
                <EasingColorKeyFrame KeyTime="00:00:00" Value="White"/>
                <EasingColorKeyFrame KeyTime="00:00:00.4000000" Value="#FF2CBEDA"/>
                <EasingColorKeyFrame KeyTime="00:00:00.8000000" Value="White"/>
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="storyRecv">
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="xRV" Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)">
                <EasingColorKeyFrame KeyTime="00:00:00" Value="#FFFDFDFD"/>
                <EasingColorKeyFrame KeyTime="00:00:00.3000000" Value="#FFE46868"/>
                <EasingColorKeyFrame KeyTime="00:00:00.6000000" Value="White"/>
            </ColorAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="xREAD" Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)">
                <EasingColorKeyFrame KeyTime="00:00:00" Value="White"/>
                <EasingColorKeyFrame KeyTime="00:00:00.3000000" Value="#FFE46868"/>
                <EasingColorKeyFrame KeyTime="00:00:00.6000000" Value="White"/>
            </ColorAnimationUsingKeyFrames>
        </Storyboard>

    </UserControl.Resources>
    <Border BorderBrush="#FF45ABAD" CornerRadius="4">
        <Border.Resources>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderThickness" Value="2" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="False">
                        <Setter Property="BorderThickness" Value="0" />
                        
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Resources>
        
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="42"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="xMODE"   Grid.Column="0" IsReadOnly="true"                                                 TextAlignment="Center"  Text="{Binding Mode}"   FontSize="10" Background="#88eeeeee"/>
        <TextBox x:Name="xCH"     Grid.Column="1" IsReadOnly="{Binding Single}"                                     TextAlignment="Center"  Text="{Binding CH}"     PreviewTextInput="HexOnlyInput"/>
        <TextBox x:Name="xADR"    Grid.Column="2" IsReadOnly="{Binding Single}"                                     TextAlignment="Center"  Text="{Binding ADR}"    PreviewTextInput="HexOnlyInput"/>
        <TextBox x:Name="xFUNC"   Grid.Column="3" IsReadOnly="true"                                                 TextAlignment="Center"  Text="{Binding FUNC}"/>
        <TextBox x:Name="xDISC"   Grid.Column="4" IsReadOnly="true"                                                                         Text="{Binding Discription}" Background="#88eeeeee" FontSize="10"/>
        <TextBox x:Name="xKind"   Grid.Column="5" IsReadOnly="true"                                                                         Text="{Binding Kind}"       Background="#88eeeeee" FontSize="10"/>

        <TextBox x:Name="xREAD"   Grid.Column="6" IsReadOnly="true"             IsEnabled="{Binding ReadEnable}"    TextAlignment="Center"  Text="{Binding Read}"       Visibility="{Binding VisibleHex}" Background="White"/>
        <TextBox x:Name="xWRITE"  Grid.Column="7"                               IsEnabled="{Binding SendEnable}"    TextAlignment="Center"  Text="{Binding Write}"      Visibility="{Binding VisibleHex}" PreviewTextInput="HexOnlyInput" BorderBrush="#FFE0E0E0" Background="White" />
        <TextBox x:Name="xRV"     Grid.Column="6" IsReadOnly="true"             IsEnabled="{Binding ReadEnable}"    TextAlignment="Center"  Text="{Binding ReadValue}"  Visibility="{Binding VisibleValue}" Background="White"                                    />
        <TextBox x:Name="xWV"     Grid.Column="7"                               IsEnabled="{Binding SendEnable}"    TextAlignment="Center"  Text="{Binding WriteValue}" Visibility="{Binding VisibleValue}" BorderBrush="#FFE0E0E0" Background="White" />

        <TextBox x:Name="xLen"    Grid.Column="8" IsReadOnly="true"                                                 TextAlignment="Center"  Text="{Binding Len}"/>
        <Button  x:Name="xSEND"   Grid.Column="9" Content="Send"                IsEnabled="{Binding SendEnable}"    VerticalAlignment="Stretch"  HorizontalAlignment="Stretch"  Click="Send_Click" Background="#FF45ABAD"/>
    </Grid>
    </Border>
</UserControl>
