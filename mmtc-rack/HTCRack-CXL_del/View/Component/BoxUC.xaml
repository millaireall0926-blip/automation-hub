<UserControl x:Class="HTCRack.View.Component.BoxUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="255">
    <Grid Margin="3">
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" Background="{Binding BoxColor}" BorderBrush="{Binding BoarderColor}">
            <Grid  Margin="0" Background="{Binding BoxColor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.7*"/>
                    <RowDefinition Height="0.6*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <TextBlock FontWeight="DemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Name}"/>
                <TextBlock Grid.Row="1" FontWeight="DemiBold" FontSize="12" Margin="0,0,30,0" HorizontalAlignment="Right" VerticalAlignment="Center" Text="습도 "/>
                <TextBlock Grid.Row="1" FontWeight="DemiBold" FontSize="12" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding HumidityValue}" Foreground="{Binding HumRateColor}"/>

            </Grid>
        </Border>
    </Grid>
</UserControl>
