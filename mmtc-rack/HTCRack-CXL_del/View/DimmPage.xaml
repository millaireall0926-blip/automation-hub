<Page x:Class="HTCRack.View.DimmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HTCRack.View"
      mc:Ignorable="d" 
      xmlns:vm="clr-namespace:HTCRack.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"  
      xmlns:uc="clr-namespace:HTCRack.View.Component"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:model="clr-namespace:HTCRack.Model"
      d:DesignHeight="780" d:DesignWidth="1060"
      Title="DimmPage">

    <Page.DataContext>
        <vm:DimmVM />
    </Page.DataContext>


    <Grid Margin="10,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="450"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderThickness="2" Style="{StaticResource BorderRegion}" Width="205" Height="292" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top">                <Grid>
                    <TextBlock Text="Fixture Selection" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>
                    <Image Source="{Binding EquipImg}" Margin="5,24,5,-2" MouseLeftButtonDown="Image_MouseLeftButtonDown"/>
                    <Rectangle x:Name="xRect_Select" Fill="#550000ff" Stroke="Blue" StrokeThickness="3" Margin="57,91,58,134"  RadiusX="4" RadiusY="4" RenderTransformOrigin="2.652,-0.4"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="2" Style="{StaticResource BorderRegion}"  Margin="10,10,10,5"  >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="6" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0,0,0">
                        <TextBlock Text="Dimm Struct Per Box" FontSize="16" FontFamily="Arial" FontWeight="DemiBold" />
                        <TextBlock Text="{Binding CurName}" Foreground="DimGray" FontSize="14" Margin="8,2,0,0" FontFamily="Arial" FontWeight="DemiBold" />
                        <TextBlock Text="{Binding BaseLineText}" Foreground="DarkGreen" Margin="20,2,0,0" FontSize="12" FontWeight="DemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding BoxDatas}" Margin="0,-9,0,3">
                        <ItemsControl.ItemsPanel >
                            <ItemsPanelTemplate>
                                <Canvas>
                                </Canvas>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <uc:DimmPageCboxUC Width="330"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!--                        -->
                    <!-- Manual Control Button  -->
                    <!--                        -->
                    <ItemsControl Grid.Row="2" Margin="0,-15,0,0"
                                  ItemsSource="{Binding ManualControls}" 
                                  Visibility="{Binding ShowManualContol}" >
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid>
                                    <Grid.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="Width" Value="22" />
                                            <Setter Property="Height" Value="18" />
                                        </Style>
                                    </Grid.Resources>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="260"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Grid.Column" Value="{Binding Index}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" >
                                    <CheckBox Content="Auto" IsChecked="{Binding IsAuto}" VerticalAlignment="Bottom" Margin="8"/>
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="10°C" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="+" Command="{Binding DGCmdPlus}" CommandParameter="10"/>
                                            <Button Grid.Column="1" Content="-" Command="{Binding DGCmdMinus}" CommandParameter="10"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="1°C" HorizontalAlignment="Center"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="+" Command="{Binding DGCmdPlus}" CommandParameter="1"/>
                                            <Button Grid.Column="1" Content="-" Command="{Binding DGCmdMinus}" CommandParameter="1"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="0.1°C" HorizontalAlignment="Center"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="+" Command="{Binding DGCmdPlus}" CommandParameter="0.1"/>
                                            <Button Grid.Column="1" Content="-" Command="{Binding DGCmdMinus}" CommandParameter="0.1"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        
                    </ItemsControl>
                    
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" BorderThickness="2" Margin="10,0,10,5" Style="{StaticResource BorderRegion}"   >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Dimm Temperature Graph" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>
                                
                <Grid Grid.Row="1" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="10*"/>
                            <RowDefinition Height="4*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Center">
                            <ToggleButton x:Name="xBoxA" Content="A" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonPrimary}" IsChecked="True" Click="xBoxA_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
                            <ToggleButton x:Name="xBoxB" Content="B" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSuccess}" IsChecked="True" Click="xBoxA_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Center">
                            <ToggleButton x:Name="xBoxC" Content="C" Margin="2,0,0,0"  Style="{StaticResource ToggleButtonWarning}" IsChecked="True" Click="xBoxA_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,5,0">
                            <TextBlock Text="ALL " Foreground="Black" VerticalAlignment="Center"></TextBlock>
                            <ToggleButton Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSwitch}" IsChecked="True"  Click="ToggleDimmAll_Click" />
                        </StackPanel>
                        <ToggleButton Grid.Row="0"  Content="AutoFit" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="30" Width="60"  HorizontalAlignment="Right"  VerticalAlignment="Top" RenderTransformOrigin="0.535,0.65"/>

                        <Grid Grid.Row="1">
                            <ItemsControl   ItemsSource="{Binding DimDatas}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding ChanelColor}" VerticalAlignment="Center"></TextBlock>
                                            <ToggleButton Uid="{Binding Name}" Margin="2,0,0,0" IsChecked="{Binding Show}" 
                                                          Style="{StaticResource ToggleButtonSwitch}" Command="{Binding DGToggle}" />
                                         </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                    <sp:WpfPlot Grid.Column="2" x:Name="xDimGraph" />
                </Grid>
            </Grid>
        </Border>


    </Grid>
</Page>
