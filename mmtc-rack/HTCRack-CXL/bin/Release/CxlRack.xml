        sv 60 인경우
          baseline = 4, step = 0.5 경우
            dimm avg가 64가 되면 -0.5 씩 sv를 낮춤.
          baseline = 2, step = 0.2 경우 
            dimm avg가 62가 되면 -0.2 씩 sv를 낮춤
    -->
    <limit use="0" baseline="4" step="0.5" />
  </dimm>
