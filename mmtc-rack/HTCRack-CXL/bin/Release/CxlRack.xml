      <Radiator-Fan under="1" over="8" />
    </utility-cur>
    <paltier-cur over="50" />
  </cur>
  <!-- Peltier Current Monitor -->
  <fet-temp under="-10" warn="40" over="10000" />
  <!-- FET Temp Monitor -->
  <defrost targettemp="60" targetwaittime="10" tempstep="1" steptime="60" />
  <dimm max="90" min="60" stable="10" limit="5" per-log="5" alarmH="90" alarmL="30" per-alarm="5" no-dimm-check="1800" SVMin="-10" SVMax="85">
