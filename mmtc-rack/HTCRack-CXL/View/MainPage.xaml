<Page x:Class="HTCRack_CXL.View.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HTCRack_CXL.View"
      mc:Ignorable="d" 
      xmlns:vm="clr-namespace:HTCRack_CXL.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"  
      xmlns:uc="clr-namespace:HTCRack_CXL.View.Component"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="MainPage">

    <Page.DataContext>
        <vm:MainPageVM/>
    </Page.DataContext>

    <Grid Margin="10,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="300"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border  Style="{StaticResource BorderRegion}" Margin="10" BorderThickness="2">
                <Grid>
                    <TextBlock Margin="0,0,0,156" Text="All Selection" FontSize="16" FontFamily="Arial" FontWeight="DemiBold" ></TextBlock>
                    <TextBlock Margin="4,47,162,129" Text="All SV" Foreground="DimGray" FontSize="12" FontFamily="Arial" FontWeight="DemiBold"  ></TextBlock>
                    <TextBox Text="{Binding SVAll}" IsEnabled="{Binding EnableSVAll}" Margin="50,40,98,0" RenderTransformOrigin="0.302,0.217" Height="21" VerticalAlignment="Top" FontSize="14"/>
                    <TextBlock Margin="123,47,71,129" Text="℃" Foreground="DimGray" FontSize="12" FontFamily="Arial" FontWeight="DemiBold" RenderTransformOrigin="1.833,0.067"  />
                    <Button Content="SET" Command="{Binding DGCmdAll}" CommandParameter="Set" IsEnabled="{Binding EnableSVAll}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0,38,10,0" VerticalAlignment="Top" Width="60" Height="30"/>

                    <Button Content="All Start" Command="{Binding DGCmdAll}" CommandParameter="Start" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,90,0,0" VerticalAlignment="Top" Width="104" Height="38"></Button>
                    <Button Content="All Stop" Command="{Binding DGCmdAll}" CommandParameter="Stop" Style="{StaticResource DangerButton}" HorizontalAlignment="Left" Width="104" Margin="112,90,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All Select" Command="{Binding DGCmdAll}" CommandParameter="Select" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="104" Margin="0,132,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All None" Command="{Binding DGCmdAll}" CommandParameter="None" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="104" Margin="112,132,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="Clear PopUp" Command="{Binding DGCmdAll}" CommandParameter="PopUpClear" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="104" Margin="112,218,0,0" VerticalAlignment="Top" Height="38"/>
                    <CheckBox IsChecked="{Binding IsTamsAll}" Content="TAMS ALL" Margin="0,2,6,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="84"/>
                    <Button Content="All Power On" Command="{Binding DGCmdAll}" CommandParameter="On" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="104" Margin="0,175,0,0" VerticalAlignment="Top" Height="38"/>
                    <Button Content="All Power Off" Command="{Binding DGCmdAll}" CommandParameter="Off" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="104" Margin="112,175,0,0" VerticalAlignment="Top" Height="38"/>

                </Grid>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource BorderRegion}" Margin="10" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Log" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>

                    <Button Content="Clear" Command="{Binding DGCmdAll}" Height="28" Margin="0,-2,-6,0" Style="{StaticResource OutlineButton}"  CommandParameter="Clear" HorizontalAlignment="Right" VerticalAlignment="Top" Width="104"/>

                    <ListView x:Name="xList_Log" Grid.Row="1" Background="White" IsSynchronizedWithCurrentItem="True" Margin="-11" 
                              ItemsSource="{Binding SysLogs}" FontSize="9" >
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}" >
                                <Setter Property="ToolTipService.Placement" Value="RelativePoint" />
                                <Setter Property="ToolTipService.HorizontalOffset" Value="0" />
                                <Setter Property="ToolTipService.VerticalOffset" Value="0" />
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=Message}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="0">
                                        <Setter Property="Foreground" Value="#FF444444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="1">
                                        <Setter Property="Foreground" Value="DarkOrange" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="2">
                                        <Setter Property="Foreground" Value="IndianRed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="96" Header="Time" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Width="500" Header="Message" DisplayMemberBinding="{Binding Message}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Column="1">
            <ItemsControl ItemsSource="{Binding Racks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding LayoutColumnCount}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <uc:RackUC/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
