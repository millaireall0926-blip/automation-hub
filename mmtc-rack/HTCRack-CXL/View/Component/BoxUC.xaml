<UserControl x:Class="HTCRack_CXL.View.Component.BoxUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack_CXL.View.Component"
             xmlns:uc="clr-namespace:HTCRack_CXL.View.Component" 
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="240">
    <Grid Margin="3">
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" BorderBrush="{Binding BoarderColor}">
            <Grid  Margin="-8" Background="{Binding BoxColor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="0.4*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource TitleText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"  />
                <Grid Grid.Row="1" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="2">
                        <TextBlock Text="습도 " FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HumidityValue}" FontSize="12" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{Binding HumRateColor}"/>
                    </Grid>
                </Grid>
                <Grid Grid.Row="2" Margin="2">
                    <ItemsControl ItemsSource="{Binding Sites}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <uc:SiteUC/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Visibility="{Binding BoxShowBox}">
                        <Rectangle x:Name="xRectMeg" Fill="{Binding BoxMsgColor}"/>
                        <TextBlock Text="{Binding BoxMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                    </Grid>
                </Grid>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="1" Content="{Binding DefostTime}" Margin="0,0,1,0" BorderThickness="0" Background="Transparent" FontWeight="DemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
