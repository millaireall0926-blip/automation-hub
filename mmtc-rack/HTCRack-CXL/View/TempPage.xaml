<Page x:Class="HTCRack_CXL.View.TempPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HTCRack_CXL.View"
      mc:Ignorable="d" 
      xmlns:vm="clr-namespace:HTCRack_CXL.ViewModel"
      xmlns:hc="https://handyorg.github.io/handycontrol"  
      xmlns:uc="clr-namespace:HTCRack_CXL.View.Component"
      xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
      xmlns:model="clr-namespace:HTCRack_CXL.Model"
      d:DesignHeight="780" d:DesignWidth="1060"
      Title="TempPage">

    <Page.DataContext>
        <vm:TempVM />
    </Page.DataContext>

    <Grid Margin="10,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="370"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Column="0" Margin="0,40,0,0">
            <Border Grid.Column="0" BorderThickness="2" Style="{StaticResource BorderRegion}" Width="205" Height="292" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top">
                <Grid>
                    <TextBlock Text="Fixture Selection" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>
                    <Image Source="{Binding EquipImg}" Margin="5,24,5,-2" MouseLeftButtonDown="Image_MouseLeftButtonDown"/>
                    <Rectangle x:Name="xRect_Select" Fill="#550000ff" Stroke="Blue" StrokeThickness="3" Margin="20, 123, 110, 107" RadiusX="4" RadiusY="4" RenderTransformOrigin="2.652,-0.4"/>
                </Grid>
            </Border>
            
        </Grid>
        <Border Grid.Column="1" Grid.RowSpan="2" BorderThickness="2" Margin="10,50,10,100" Style="{StaticResource BorderRegion}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Dimm Temperature Graph" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"/>

                <Grid Grid.Row="1" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="10*"/>
                            <RowDefinition Height="4*"/>
                        </Grid.RowDefinitions>
                        
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,5,0">
                            <TextBlock Text="{Binding CurName}" VerticalAlignment="Center" Foreground="DimGray" FontSize="16" Margin="8,2,0,0" FontFamily="Arial" FontWeight="DemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,5,0">
                            <TextBlock Text="ALL " Foreground="Black" VerticalAlignment="Center"></TextBlock>
                            <ToggleButton Margin="2,0,0,0"  Style="{StaticResource ToggleButtonSwitch}" IsChecked="True"  Click="ToggleDimmAll_Click" />
                        </StackPanel>
                        <ToggleButton Grid.Row="1"  Content="AutoFit" IsChecked="{Binding AutoFit}" Style="{StaticResource ToggleButtonPrimary}" Height="30" Width="60"  HorizontalAlignment="Right"  VerticalAlignment="Top" RenderTransformOrigin="0.535,0.65"/>

                        <Grid Grid.Row="3">
                            <ItemsControl   ItemsSource="{Binding TempDatas}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding ChannelColor}" VerticalAlignment="Center"></TextBlock>
                                            <ToggleButton Uid="{Binding Name}" Margin="2,0,0,0" IsChecked="{Binding Show}" 
                                              Style="{StaticResource ToggleButtonSwitch}" Command="{Binding DGToggle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                    <sp:WpfPlot Grid.Column="2" x:Name="xDimGraph" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
