<UserControl x:Class="HTCRack.View.Component.RackUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack.View.Component"
             xmlns:vm="clr-namespace:HTCRack.ViewModel"
             xmlns:hc="https://handyorg.github.io/handycontrol"  
             xmlns:uc="clr-namespace:HTCRack.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid Margin="0,5,2,5" >
        <Border BorderThickness="3" Style="{StaticResource BorderRegion}" BorderBrush="{Binding BoarderColor}" >
            <Grid Background="{Binding RackColor}" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,1,0,9">
                    <!-- Check Box Area -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="TC Unit" Margin="5,0,0,0" IsChecked="{Binding IsTCUnit}" />
                    <CheckBox Grid.Column="1" Content="TAMS" IsChecked="{Binding IsTams}"/>
                    <CheckBox Grid.Column="2" Content="Save Temp" Visibility="{Binding ShowOnlyTemp}" HorizontalAlignment="Right" Margin="0,0,10,0" IsChecked="{Binding IsSaveOnlyTemp}"/>
                    <CheckBox Grid.Column="3" Content="AS" HorizontalAlignment="Right" Margin="0,0,10,0" IsChecked="{Binding IsAS}"/>
                </Grid>
                <Grid Grid.Row="1">
                    <!-- Name SV PV Area -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="16" FontFamily="Arial" FontWeight="DemiBold"  />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock VerticalAlignment="Center" Text="SV" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtSV" Width="60" Text="{Binding SetSV, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding EnableSV}" FontSize="14" >
                            <TextBox.InputBindings>
                                <KeyBinding Command="{Binding DGCmdSetTemp}" Key="Enter"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock VerticalAlignment="Center" Text="℃" Margin="5,0,10,0"/>
                        <TextBlock VerticalAlignment="Center" Text="PV(MAX)" Margin="0,0,5,0"/>
                        <TextBox Width="60" Text="{Binding MaxPV}" IsReadOnly="True" FontSize="14"/>
                        <TextBlock VerticalAlignment="Center" Text="℃" Margin="5,0,10,0"/>
                    </StackPanel>

                </Grid>
                <Grid Grid.Row="2" >
                    <!-- CBox Area-->
                    <ItemsControl ItemsSource="{Binding CBoxs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <uc:CBoxUC/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                <Grid Grid.Row ="2" Visibility="{Binding ShowBox}">
                    <Rectangle Fill="{Binding BoxColor}"/>
                    <TextBlock Text="{Binding BoxMsg}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="굴림" FontWeight="Bold"></TextBlock>
                </Grid>

                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <!-- Run/Stop Area-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        
                        

                    </Grid.ColumnDefinitions>
                    <Button Content="Run" Width="68" Command="{Binding DGCmdRun}" CommandParameter="{Binding RackStat}"/>
                    <Button Grid.Column="1" Content="Stop" Width="68" Command="{Binding DGCmdStop}" CommandParameter="{Binding RackStat}"/>
                    <TextBox Grid.Column="2" IsReadOnly="True" Text="{Binding StatText}" BorderThickness="2" BorderBrush="Black" Background="{Binding BoarderColor}"/>
                    <Button Grid.Column="3"  Width="68" Command="{Binding DGCmdPower}" CommandParameter="{Binding PowerStat}" Margin="6,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>

                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PowerStat}" Value="0">
                                        <Setter Property="Content" Value="PLC Off"/>
                                        <Setter Property="Background" Value="Gray" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PowerStat}" Value="1">
                                        <Setter Property="Content" Value="Power Off"/>
                                        <Setter Property="Background" Value="LightGray" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PowerStat}" Value="2">
                                        <Setter Property="Content" Value="Power Mix"/>
                                        <Setter Property="Background" Value="LightBlue" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PowerStat}" Value="3">
                                        <Setter Property="Content" Value="Power On"/>
                                        <Setter Property="Background" Value="LightGreen" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PowerStat}" Value="4">
                                        <Setter Property="Content" Value="Changing"/>
                                        <Setter Property="Background" Value="LightBlue" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>

                    
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
