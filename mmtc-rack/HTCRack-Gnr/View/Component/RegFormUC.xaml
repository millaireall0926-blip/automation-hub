<UserControl x:Class="HTCRack.View.Component.RegFormUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack.View.Component"
             xmlns:uc="clr-namespace:HTCRack.View.Component"
             xmlns:hc="https://handyorg.github.io/handycontrol"  
             x:Name="UCForm"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="84"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" HorizontalAlignment="Center" Text="TYPE" Foreground="DarkBlue"/>
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" Text="Mode" Foreground="DarkBlue"/>
            <TextBlock Grid.Column="2" HorizontalAlignment="Center" Text="CH/ADR/FUN" Foreground="DarkBlue"/>
            <TextBlock Grid.Column="3" HorizontalAlignment="Center" Text="Description" Foreground="DarkBlue"/>
            
            <TextBlock Grid.Column="5" HorizontalAlignment="Center" Text="Read" Foreground="DarkBlue"/>
            <TextBlock Grid.Column="6" HorizontalAlignment="Center" Text="Write" Foreground="DarkBlue"/>
            <TextBlock Grid.Column="7" HorizontalAlignment="Center" Text="Len" Foreground="DarkBlue"/>
            <TextBlock x:Name="xValueHead" Grid.Column="8" HorizontalAlignment="Center" Text="Send" Foreground="DarkBlue"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="xType"  VerticalAlignment="Stretch" TextAlignment="Center" IsReadOnly="true" FontWeight="DemiBold" FontSize="14" Background="LightGray"/>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding Path=ItemsSource, ElementName=UCForm}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <uc:RegisterUC/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
