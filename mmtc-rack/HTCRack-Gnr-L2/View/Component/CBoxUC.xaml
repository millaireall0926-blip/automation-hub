<UserControl x:Class="HTCRack.View.Component.CBoxUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HTCRack.View.Component"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="500">
    <Grid Margin="0,8,0,0">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" Margin="5,0,10,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding BoxTemp}" FontSize="13" IsReadOnly="True" Width="45" Margin="7" VerticalAlignment="Center"/>
            </StackPanel>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding DimModels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DimColumns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" BorderBrush="#aa000000" Margin="2" Height="28" MaxWidth="50" CornerRadius="3">
                            <TextBox Background="{Binding DimColor}" Text="{Binding DimText}" FontSize="13" FontWeight="DemiBold" TextAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <TextBox.Resources>
                                    <Style TargetType="TextBox"></Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <Rectangle Fill="{Binding BoxColor}" RadiusX="4" RadiusY="4"></Rectangle>
    </Grid>
</UserControl>
